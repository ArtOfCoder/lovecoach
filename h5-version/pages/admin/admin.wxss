/* pages/admin/admin.wxss - 管理后台样式 */

.admin-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

/* 登录页 */
.login-section {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 80vh;
}

.login-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 50rpx;
  width: 100%;
  max-width: 600rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.login-title {
  font-size: 48rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 16rpx;
  color: #333;
}

.login-subtitle {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-bottom: 50rpx;
}

.password-input {
  width: 100%;
  height: 96rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 32rpx;
  box-sizing: border-box;
  margin-bottom: 40rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B8A, #FF8E8E);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

/* 管理面板 */
.admin-panel {
  padding-bottom: 40rpx;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #FF6B8A, #FF8E8E);
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 138, 0.3);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.stat-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 操作栏 */
.action-bar {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.action-btn.refresh {
  color: #FF6B8A;
}

.action-btn.clear {
  color: #ff4444;
}

/* 记录列表 */
.records-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.record-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-order {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  font-family: monospace;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.record-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #52c41a;
}

.record-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-type {
  font-size: 26rpx;
  color: #666;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

.record-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.record-action {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.record-action.screenshot {
  background: #e6f7ff;
  color: #1890ff;
}

.record-action.ban {
  background: #fff1f0;
  color: #ff4d4f;
}

.record-action.unban {
  background: #f6ffed;
  color: #52c41a;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  padding: 30rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.tab-item.active {
  color: #FF6B8A;
  font-weight: 600;
  background: rgba(255, 107, 138, 0.05);
}

.tab-badge {
  background: #ff4d4f;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
}

/* 封禁状态 */
.record-item.banned {
  background: #fff1f0;
  border: 2rpx solid #ffccc7;
}

.banned-tag {
  background: #ff4d4f;
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-left: auto;
}

.ban-reason {
  margin-top: 12rpx;
  padding: 16rpx;
  background: rgba(255, 77, 79, 0.05);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #ff4d4f;
}

/* 用户信息 */
.record-user {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  padding: 12rpx 16rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.user-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e0e0e0;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.user-id {
  font-size: 22rpx;
  color: #999;
  font-family: monospace;
  margin-left: auto;
}

/* 底部提示 */
.admin-footer {
  text-align: center;
  margin-top: 40rpx;
  padding: 20rpx;
}

.admin-footer text {
  font-size: 24rpx;
  color: #999;
}

/* ===== 手动解锁区域 ===== */
.unlock-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.unlock-card {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 30rpx;
}

.unlock-desc {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.unlock-desc text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.unlock-input {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.unlock-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #52c41a, #73d13d);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

/* 最近解锁记录 */
.unlock-record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.unlock-record-item:last-child {
  border-bottom: none;
}

.unlock-record-id {
  font-size: 26rpx;
  color: #333;
  font-family: monospace;
  background: #f0f0f0;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.unlock-record-time {
  font-size: 24rpx;
  color: #999;
}

/* 使用说明 */
.unlock-tips {
  margin-top: 40rpx;
  padding: 24rpx;
  background: #e6f7ff;
  border-radius: 16rpx;
  border: 2rpx solid #91d5ff;
}

.unlock-tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1890ff;
  margin-bottom: 16rpx;
}

.unlock-tip-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

/* ===== 黑名单区域 ===== */
.banned-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

/* 封禁输入弹窗 */
.ban-input-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ban-input-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.ban-input-content {
  position: relative;
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.ban-input-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.ban-input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 30rpx;
}

.ban-input-actions {
  display: flex;
  gap: 20rpx;
}

.ban-input-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.ban-input-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.ban-input-btn.confirm {
  background: #ff4d4f;
  color: #fff;
}

.add-ban-btn {
  width: 100%;
  height: 80rpx;
  background: #fff1f0;
  border: 2rpx solid #ffccc7;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff4d4f;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.banned-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.banned-item:last-child {
  border-bottom: none;
}

.banned-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.banned-id {
  font-size: 28rpx;
  color: #333;
  font-family: monospace;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.banned-info {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.banned-reason {
  font-size: 26rpx;
  color: #ff4d4f;
  margin-bottom: 16rpx;
}

.banned-actions {
  display: flex;
  justify-content: flex-end;
}

.unban-btn {
  padding: 12rpx 32rpx;
  background: #f6ffed;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #52c41a;
}

/* ===== 解锁按钮组 ===== */
.unlock-actions {
  display: flex;
  gap: 20rpx;
}

.unlock-btn.primary {
  flex: 2;
}

.unlock-btn.secondary {
  flex: 1;
  background: linear-gradient(135deg, #1890ff, #40a9ff);
}

.unlock-record-type {
  font-size: 22rpx;
  color: #52c41a;
  background: #f6ffed;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* ===== 灵魂伴侣解锁管理 ===== */
.soulmate-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.soulmate-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.soulmate-item:last-child {
  border-bottom: none;
}

.soulmate-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.soulmate-id {
  font-size: 28rpx;
  color: #333;
  font-family: monospace;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.soulmate-tags {
  display: flex;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.tag.unlock-type {
  color: #52c41a;
  background: #f6ffed;
}

.soulmate-info {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.soulmate-actions {
  display: flex;
  justify-content: flex-end;
}

.revoke-btn {
  padding: 12rpx 32rpx;
  background: #fff1f0;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #ff4d4f;
}

/* ===== OCR识别记录 ===== */
.ocr-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* ===== 支付记录 ===== */
.payments-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.payment-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.payment-item:last-child {
  border-bottom: none;
}

.payment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.payment-order {
  font-size: 26rpx;
  color: #333;
  font-family: monospace;
  background: #f0f0f0;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.payment-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #52c41a;
}

.payment-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.payment-info text {
  font-size: 24rpx;
  color: #666;
}

.payment-status {
  display: flex;
  justify-content: flex-end;
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.status-tag.success {
  background: #f6ffed;
  color: #52c41a;
}

.status-tag.pending {
  background: #fffbe6;
  color: #faad14;
}

.status-tag.failed {
  background: #fff1f0;
  color: #ff4d4f;
}

/* ===== 统计页面 ===== */
.stats-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stats-card-item {
  background: linear-gradient(135deg, #FF6B8A, #FF8E8E);
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
}

.stats-card-item .stats-number {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.stats-card-item .stats-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.log-item {
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.log-item:last-child {
  border-bottom: none;
}

.log-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.log-action {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.log-time {
  font-size: 22rpx;
  color: #999;
}

.log-user {
  font-size: 24rpx;
  color: #666;
}

.ocr-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.ocr-item:last-child {
  border-bottom: none;
}

.ocr-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.ocr-user {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
}

.ocr-time {
  font-size: 24rpx;
  color: #999;
}

.ocr-text {
  font-size: 24rpx;
  color: #666;
  background: #f8f8f8;
  padding: 16rpx;
  border-radius: 12rpx;
  line-height: 1.6;
  word-break: break-all;
}

/* 统计卡片 */
.stats-card .stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-card .stats-number {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.stats-card .stats-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}
