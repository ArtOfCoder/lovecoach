/* pages/index/index.wxss */

.page-wrap {
  min-height: 100vh;
  background: #f8f8fc;
  padding-bottom: 40rpx;
}

/* Hero */
.hero {
  padding: 48rpx 32rpx 32rpx;
}
.hero-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 28rpx;
}
.hero-left { flex: 1; }
.hero-greeting {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  margin-bottom: 4rpx;
}
.hero-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 6rpx;
}
.hero-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}
.hero-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}
.hero-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 700;
  border: 3rpx solid rgba(255,255,255,0.5);
}
.streak-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  background: #f97316;
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 100rpx;
  font-weight: 700;
}

/* 性别切换 */
.gender-switch {
  display: flex;
  gap: 16rpx;
}
.gender-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 28rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  background: rgba(255,255,255,0.22);
  color: rgba(255,255,255,0.9);
  gap: 6rpx;
}
.gender-btn.active {
  background: #ffffff;
  color: #FF6B8A;
  font-weight: 700;
}

/* AI 配置提示横幅 */
.ai-config-tip {
  background: linear-gradient(135deg, #f59e0b, #FF6B8A);
  padding: 16rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.act-icon { font-size: 28rpx; }
.act-text { font-size: 24rpx; color: #fff; font-weight: 600; flex: 1; }

/* 通用section包裹 */
.section-wrap {
  padding: 20rpx 24rpx 0;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.section-title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}
.section-more {
  font-size: 26rpx;
  color: #FF6B8A;
}

/* 今日任务 */
.daily-task-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.07);
}
.daily-task-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}
.daily-icon { font-size: 48rpx; flex-shrink: 0; }
.daily-task-info { flex: 1; }
.daily-task-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 4rpx;
}
.daily-task-sub {
  font-size: 24rpx;
  color: #666666;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}
.daily-task-right { flex-shrink: 0; margin-left: 16rpx; }
.daily-task-btn {
  background: #FF6B8A;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
}
.daily-task-btn.done {
  background: #dcfce7;
  color: #16a34a;
}

/* 今日金句 */
.daily-word-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
}
.dw-left { flex: 1; margin-right: 16rpx; }
.dw-tag {
  font-size: 22rpx;
  color: #FF6B8A;
  font-weight: 600;
  margin-bottom: 10rpx;
}
.dw-text {
  font-size: 28rpx;
  color: #1a1a2e;
  line-height: 1.6;
  font-style: italic;
}
.dw-share {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #FF6B8A;
  border: 1rpx solid #FF6B8A;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
}

/* 四宫格 */
.quick-grid {
  display: flex;
  gap: 16rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.07);
}
.quick-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  position: relative;
}
.quick-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}
.quick-label {
  font-size: 24rpx;
  color: #666666;
  text-align: center;
}
.quick-badge {
  position: absolute;
  top: -6rpx;
  right: 4rpx;
  background: #ef4444;
  color: #fff;
  font-size: 18rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}
.quick-new {
  position: absolute;
  top: -6rpx;
  right: 4rpx;
  background: #f97316;
  color: #fff;
  font-size: 16rpx;
  padding: 2rpx 8rpx;
  border-radius: 100rpx;
  font-weight: 700;
}

/* AI场景卡片 */
.ai-scenario-card {
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.ais-left { flex: 1; }
.ais-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}
.ais-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.5;
  margin-bottom: 16rpx;
}
.ais-start {
  font-size: 26rpx;
  color: rgba(255,255,255,0.95);
  font-weight: 600;
}
.ais-emoji { font-size: 72rpx; flex-shrink: 0; margin-left: 16rpx; }

/* 横向课程滚动 */
.course-hscroll {
  width: 100%;
}
.course-hscroll-inner {
  display: flex;
  gap: 16rpx;
  padding-right: 24rpx;
}
.course-h-card {
  width: 380rpx;
  flex-shrink: 0;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.07);
}
.chc-cover {
  height: 150rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.chc-emoji { font-size: 60rpx; }
.chc-free {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background: #22c55e;
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 12rpx;
  border-radius: 100rpx;
}
.chc-info { padding: 16rpx 20rpx; }
.chc-cat {
  font-size: 22rpx;
  color: #FF6B8A;
  background: #FFE8EE;
  display: inline-block;
  padding: 2rpx 14rpx;
  border-radius: 100rpx;
  margin-bottom: 8rpx;
}
.chc-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 8rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.4;
}
.chc-meta {
  font-size: 22rpx;
  color: #999999;
}

/* 热门问题 */
.hot-questions {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.07);
}
.hot-q-item {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  border-bottom: 1rpx solid #f8f8f8;
  gap: 16rpx;
}
.hot-q-item:last-child { border-bottom: none; }
.hot-q-icon {
  width: 44rpx;
  height: 44rpx;
  background: #FFE8EE;
  color: #FF6B8A;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.hot-q-text {
  flex: 1;
  font-size: 26rpx;
  color: #1a1a2e;
  line-height: 1.4;
}
.hot-q-arrow { color: #cccccc; font-size: 28rpx; }

/* 进度卡片 */
.progress-card {
  padding: 28rpx;
}
.progress-stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 24rpx;
}
.ps-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.ps-num {
  font-size: 52rpx;
  font-weight: 800;
  color: #FF6B8A;
  line-height: 1;
}
.ps-label {
  font-size: 22rpx;
  color: #999999;
}
.ps-divider {
  width: 1rpx;
  height: 64rpx;
  background: #f0f0f0;
}
.progress-bar-wrap {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.progress-track {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 100rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B8A, #FF8E53);
  border-radius: 100rpx;
  transition: width 0.6s ease;
}
.progress-tip {
  font-size: 24rpx;
  color: #999999;
}

/* ===== 首页核心功能 Banner ===== */
.hero-feature-card {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border-radius: 24rpx;
  padding: 36rpx 32rpx 28rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 30rpx rgba(26,26,46,.25);
}
.hfc-badge {
  display: inline-block;
  font-size: 22rpx;
  background: linear-gradient(135deg, #FF6B8A, #f59e0b);
  color: #fff;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  font-weight: 600;
}
.hfc-title { font-size: 40rpx; font-weight: 800; color: #fff; margin-bottom: 8rpx; }
.hfc-sub { font-size: 26rpx; color: rgba(255,255,255,.7); margin-bottom: 24rpx; }
.hfc-demo {
  background: rgba(255,255,255,.08);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.demo-bubble-ta {
  background: rgba(255,255,255,.15);
  color: rgba(255,255,255,.85);
  font-size: 24rpx;
  padding: 14rpx 20rpx;
  border-radius: 0 16rpx 16rpx 16rpx;
  align-self: flex-start;
  max-width: 70%;
}
.demo-arrow {
  font-size: 22rpx;
  color: rgba(255,255,255,.4);
  text-align: center;
}
.demo-bubble-me {
  background: linear-gradient(135deg, #4F8EF7, #6C63FF);
  color: #fff;
  font-size: 24rpx;
  padding: 14rpx 20rpx;
  border-radius: 16rpx 0 16rpx 16rpx;
  align-self: flex-end;
  max-width: 85%;
  line-height: 1.6;
}
.hfc-btn {
  background: linear-gradient(135deg, #FF6B8A, #6C63FF);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  padding: 22rpx;
  border-radius: 30rpx;
  letter-spacing: 1rpx;
}

/* ===== 双卡片行 ===== */
.dual-card-row { display: flex; gap: 16rpx; }
.dual-card {
  flex: 1;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06);
}
.dc-icon { font-size: 48rpx; margin-bottom: 10rpx; }
.dc-title { font-size: 28rpx; font-weight: 700; color: #1a1a2e; margin-bottom: 8rpx; }
.dc-sub { font-size: 22rpx; color: #888; line-height: 1.5; }
.dc-badge {
  position: absolute;
  top: 16rpx; right: 16rpx;
  background: linear-gradient(135deg, #FF6B8A, #6C63FF);
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 700;
}

/* ===== 功能宫格（4宫格行版） ===== */
.quick-grid-4 { display: flex; gap: 14rpx; }
.qg-cell {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 10rpx;
  display: flex; flex-direction: column; align-items: center; gap: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,.04);
}
.qg-icon {
  width: 72rpx; height: 72rpx;
  border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx;
}
.qg-label { font-size: 24rpx; color: #444; font-weight: 600; text-align: center; }

/* ===== 新用户引导横幅 ===== */
.new-user-guide {
  margin: 20rpx 24rpx 0;
  background: linear-gradient(135deg, #FF6B8A 0%, #A855F7 60%, #6C63FF 100%);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 6rpx 24rpx rgba(255,107,138,.3);
}
.nug-icon { font-size: 44rpx; flex-shrink: 0; }
.nug-content { flex: 1; min-width: 0; }
.nug-title { font-size: 28rpx; font-weight: 700; color: #fff; margin-bottom: 6rpx; }
.nug-sub { font-size: 22rpx; color: rgba(255,255,255,.85); line-height: 1.5; }
.nug-btn {
  flex-shrink: 0;
  background: rgba(255,255,255,.25);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  padding: 14rpx 22rpx;
  border-radius: 30rpx;
  white-space: nowrap;
  border: 1rpx solid rgba(255,255,255,.4);
}

/* ===== 灵魂伴侣 Banner ===== */
.soulmate-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 4rpx 24rpx rgba(80, 40, 180, 0.3);
}

.soulmate-banner::after {
  content: '';
  position: absolute;
  top: -40%;
  right: -10%;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(180, 80, 255, 0.2) 0%, transparent 70%);
}

.smb-left {
  flex: 1;
  padding-right: 20rpx;
}

.smb-tag {
  font-size: 20rpx;
  color: rgba(180, 150, 255, 0.9);
  background: rgba(180, 80, 255, 0.2);
  border-radius: 100rpx;
  padding: 4rpx 16rpx;
  display: inline-block;
  margin-bottom: 12rpx;
  border: 1rpx solid rgba(180, 100, 255, 0.3);
}

.smb-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

.smb-sub {
  font-size: 22rpx;
  color: rgba(200, 180, 255, 0.7);
  line-height: 1.5;
}

.smb-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.smb-avatar-demo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f5a7c7, #a78bfa, #60a5fa);
  display: flex;
  align-items: center;
  justify-content: center;
  filter: blur(4rpx);
  box-shadow: 0 0 20rpx rgba(180, 100, 255, 0.5);
}

.smb-blur-face {
  font-size: 40rpx;
  filter: blur(2rpx);
}

.smb-price {
  font-size: 22rpx;
  color: #ffd700;
  background: rgba(255, 215, 0, 0.15);
  border-radius: 100rpx;
  padding: 4rpx 16rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.3);
  white-space: nowrap;
}
