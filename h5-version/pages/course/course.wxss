/* pages/course/course.wxss */

.container {
  min-height: 100vh;
  background: var(--bg);
}

.header {
  padding: 48rpx 32rpx 40rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 8rpx;
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background: #fff;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--text-sub);
  position: relative;
}

.filter-tab.active {
  color: var(--primary);
  font-weight: 600;
}

.filter-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 100rpx;
}

/* 分类标签 */
.cat-scroll {
  background: #fff;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}

.cat-inner {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx;
}

.cat-tag {
  flex-shrink: 0;
  padding: 10rpx 28rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  background: #f5f5f5;
  color: var(--text-sub);
}

.cat-tag.cat-active {
  background: var(--primary-light);
  color: var(--primary);
  font-weight: 600;
}

/* 课程列表 */
.course-list {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.course-item {
  display: flex;
  overflow: hidden;
}

.item-cover {
  width: 160rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  min-height: 160rpx;
}

.item-emoji {
  font-size: 56rpx;
}

.free-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  background: #22c55e;
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 100rpx;
}

.done-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: rgba(0,0,0,0.4);
  color: #fff;
  font-size: 20rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.item-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.item-gender-tag {
  font-size: 22rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
  line-height: 1.4;
}

.item-desc {
  font-size: 24rpx;
  color: var(--text-sub);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.item-footer {
  display: flex;
  gap: 20rpx;
}

.item-duration, .item-views {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* ===== AI 课程生成 Banner ===== */
.ai-course-banner {
  margin: 0 24rpx 24rpx;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.acb-left { display: flex; align-items: center; gap: 16rpx; flex: 1; }
.acb-icon { font-size: 44rpx; }
.acb-title { font-size: 28rpx; font-weight: 700; color: #fff; margin-bottom: 6rpx; }
.acb-sub { font-size: 22rpx; color: rgba(255,255,255,.6); }
.acb-btn {
  background: linear-gradient(135deg, #FF6B8A, #6C63FF);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  min-width: 90rpx;
  text-align: center;
}
.acb-loading { opacity: .6; }

/* ===== AI 课程区 ===== */
.ai-section { margin: 0 24rpx 20rpx; }
.ai-section-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.ai-section-title { font-size: 28rpx; font-weight: 700; color: #6C63FF; }
.ai-section-clear { font-size: 24rpx; color: #999; }
.ai-course-card { border: 1rpx solid #6C63FF22; }
.tag-ai {
  background: linear-gradient(135deg, #4F8EF722, #6C63FF22);
  color: #6C63FF;
  font-size: 20rpx;
  padding: 3rpx 12rpx;
  border-radius: 8rpx;
}

/* ===== 热门标签 ===== */
.hot-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 22rpx;
  background: rgba(0,0,0,.3);
  padding: 2rpx 8rpx;
  border-radius: 10rpx;
}

/* ===== 标题行 ===== */
.section-title-row {
  padding: 0 24rpx 12rpx;
}
.section-ttl-txt {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.empty {
  text-align: center;
  color: #999;
  padding: 60rpx;
  font-size: 28rpx;
}
