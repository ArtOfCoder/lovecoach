}

/* ===== 用户ID显示区域 ===== */
.user-id-section {
  margin: 32rpx 0 24rpx;
  padding: 28rpx 24rpx;
  background: linear-gradient(145deg, rgba(123, 63, 228, 0.15) 0%, rgba(255, 107, 138, 0.1) 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(123, 63, 228, 0.3);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.user-id-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.3) 50%, transparent 100%);
}

.user-id-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.user-id-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffd700;
  font-family: monospace;
  background: rgba(0, 0, 0, 0.2);
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  display: inline-block;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.3);
}

.user-id-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.4;
}

/* AI免责声明 */
.ai-disclaimer {
  margin: 20rpx 40rpx;
  padding: 16rpx 24rpx;
  background: rgba(0, 0, 0, 0.15);
  border-radius: 12rpx;
  text-align: center;
}

.ai-disclaimer-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.4;
}

/* 打赏说明 */
.pay-notice {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.pay-notice-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.5;
  text-align: center;
  display: block;
}

/* ===== 支付指引（加微信解锁方式）===== */
.pay-guide-section {
  margin: 32rpx 0;
  padding: 32rpx 28rpx;
  background: linear-gradient(145deg, rgba(255, 215, 0, 0.1) 0%, rgba(255, 215, 0, 0.05) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.25);
}

.pay-guide-title {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.pay-guide-icon {
  font-size: 36rpx;
}

.pay-guide-title text:last-child {
  font-size: 32rpx;
  font-weight: bold;
  color: rgba(255, 215, 0, 0.95);
}

.pay-guide-steps {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.pay-guide-step {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
}

.pay-guide-num {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.8), rgba(255, 180, 0, 0.8));
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: bold;
  color: #1a1a2e;
  flex-shrink: 0;
}

.pay-guide-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.pay-guide-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 500;
}

.pay-guide-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
}

.pay-guide-arrow {
  text-align: center;
  font-size: 32rpx;
  color: rgba(255, 215, 0, 0.6);
  line-height: 1;
}

/* ===== 截图上传弹窗样式 ===== */
.screenshot-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.screenshot-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(10rpx);
}

.screenshot-modal-content {
  position: relative;
  width: 640rpx;
  max-height: 85vh;
  background: linear-gradient(145deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 32rpx;
  border: 2rpx solid rgba(255, 107, 138, 0.3);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.screenshot-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.screenshot-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.screenshot-modal-close {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.6);
  padding: 8rpx 16rpx;
  line-height: 1;
}

.screenshot-modal-close:active {
  color: rgba(255, 255, 255, 0.9);
}

.screenshot-modal-body {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

/* 上传区域 */
.screenshot-upload-area {
  margin-bottom: 32rpx;
}

.screenshot-upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx dashed rgba(255, 107, 138, 0.4);
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  transition: all 0.3s ease;
}

.screenshot-upload-placeholder:active {
  background: rgba(255, 107, 138, 0.1);
  border-color: rgba(255, 107, 138, 0.6);
}

.upload-placeholder-icon {
  font-size: 64rpx;
}

.upload-placeholder-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.upload-placeholder-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
}

/* 截图预览 */
.screenshot-preview-wrap {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.screenshot-preview-image {
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.2);
}

.screenshot-preview-actions {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 24rpx;
}

.screenshot-action-btn {
  font-size: 26rpx;
  color: rgba(255, 107, 138, 0.9);
  padding: 12rpx 28rpx;
  border-radius: 100rpx;
  background: rgba(255, 107, 138, 0.1);
  border: 1rpx solid rgba(255, 107, 138, 0.2);
}

.screenshot-action-btn.delete {
  color: rgba(255, 80, 80, 0.9);
  background: rgba(255, 80, 80, 0.1);
  border-color: rgba(255, 80, 80, 0.2);
}

/* 截图要求 */
.screenshot-requirements {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.screenshot-req-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.screenshot-req-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.req-check {
  color: #4ade80;
  font-weight: bold;
}

/* 警告提示 */
.screenshot-warning {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: rgba(255, 107, 138, 0.1);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid rgba(255, 107, 138, 0.2);
}

.warning-icon {
  font-size: 28rpx;
}

.warning-text {
  font-size: 24rpx;
  color: rgba(255, 107, 138, 0.9);
  line-height: 1.4;
}

/* 底部按钮 */
.screenshot-modal-footer {
  padding: 24rpx 32rpx 32rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.screenshot-submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF6B8A 0%, #7B3FE4 100%);
  border-radius: 100rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 138, 0.4);
}

.screenshot-submit-btn.disabled {
  opacity: 0.5;
  background: linear-gradient(135deg, #666 0%, #444 100%);
  box-shadow: none;
}

.screenshot-submit-btn:not(.disabled):active {
  transform: scale(0.98);
}

.submit-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

/* AI自动识别提示 */
.screenshot-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: rgba(82, 196, 26, 0.1);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid rgba(82, 196, 26, 0.2);
  margin-bottom: 16rpx;
}

.info-icon {
  font-size: 28rpx;
}

.info-text {
  font-size: 24rpx;
  color: rgba(82, 196, 26, 0.9);
  line-height: 1.4;
  flex: 1;
}

.screenshot-contact-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.screenshot-contact-btn:active {
  color: rgba(255, 255, 255, 0.9);
}
