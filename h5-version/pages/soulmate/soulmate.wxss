/* pages/soulmate/soulmate.wxss - 灵魂伴侣页面样式 */

/* ===== 全局 ===== */
.soulmate-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #0f0c29 0%, #302b63 40%, #24243e 100%);
  padding-bottom: 60rpx;
  position: relative;
}

/* 背景装饰 - 星空效果 */
.soulmate-page::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(2rpx 2rpx at 20rpx 30rpx, rgba(255,255,255,0.3), transparent),
    radial-gradient(2rpx 2rpx at 40rpx 70rpx, rgba(255,255,255,0.2), transparent),
    radial-gradient(1rpx 1rpx at 90rpx 40rpx, rgba(255,255,255,0.3), transparent),
    radial-gradient(2rpx 2rpx at 160rpx 120rpx, rgba(255,255,255,0.2), transparent),
    radial-gradient(1rpx 1rpx at 230rpx 80rpx, rgba(255,255,255,0.3), transparent),
    radial-gradient(2rpx 2rpx at 300rpx 150rpx, rgba(255,255,255,0.2), transparent),
    radial-gradient(1rpx 1rpx at 350rpx 50rpx, rgba(255,255,255,0.3), transparent),
    radial-gradient(2rpx 2rpx at 400rpx 200rpx, rgba(255,255,255,0.2), transparent),
    radial-gradient(1rpx 1rpx at 450rpx 100rpx, rgba(255,255,255,0.3), transparent),
    radial-gradient(2rpx 2rpx at 500rpx 250rpx, rgba(255,255,255,0.2), transparent),
    radial-gradient(1rpx 1rpx at 550rpx 180rpx, rgba(255,255,255,0.3), transparent),
    radial-gradient(2rpx 2rpx at 600rpx 300rpx, rgba(255,255,255,0.2), transparent),
    radial-gradient(1rpx 1rpx at 650rpx 220rpx, rgba(255,255,255,0.3), transparent),
    radial-gradient(2rpx 2rpx at 700rpx 350rpx, rgba(255,255,255,0.2), transparent);
  pointer-events: none;
  z-index: 0;
}

/* ===== 步骤1：输入页 ===== */
.step-input {
  padding: 0 0 40rpx;
  position: relative;
  z-index: 1;
}

/* 头部装饰 */
.header-deco {
  text-align: center;
  padding: 80rpx 40rpx 40rpx;
  position: relative;
}

/* 头部光晕效果 */
.header-deco::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 107, 138, 0.15) 0%, transparent 70%);
  pointer-events: none;
}

.star-ring {
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto 32rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle, rgba(255, 107, 138, 0.2) 0%, transparent 70%);
  border-radius: 50%;
}

.big-star {
  font-size: 88rpx;
  animation: pulse 2s ease-in-out infinite;
  filter: drop-shadow(0 0 20rpx rgba(255, 200, 100, 0.6));
}

.zodiac-float {
  position: absolute;
  font-size: 28rpx;
  color: rgba(255, 200, 120, 0.85);
  animation: floatOrbit 8s linear infinite;
}
.z1 { top: 0; left: 50%; transform: translateX(-50%); animation-delay: 0s; }
.z2 { right: 0; top: 50%; transform: translateY(-50%); animation-delay: -2s; }
.z3 { bottom: 0; left: 50%; transform: translateX(-50%); animation-delay: -4s; }
.z4 { left: 0; top: 50%; transform: translateY(-50%); animation-delay: -6s; }

@keyframes floatOrbit {
  0% { opacity: 0.4; transform: scale(0.8) translateX(-50%); }
  50% { opacity: 1; transform: scale(1.2) translateX(-50%); }
  100% { opacity: 0.4; transform: scale(0.8) translateX(-50%); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.header-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
  text-shadow: 0 0 30rpx rgba(255, 107, 138, 0.8), 0 0 60rpx rgba(180, 80, 255, 0.4);
  background: linear-gradient(135deg, #fff 0%, #ffd4e5 50%, #e8d4ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.header-sub {
  font-size: 28rpx;
  color: rgba(255, 220, 255, 0.75);
  line-height: 1.7;
  max-width: 500rpx;
  margin: 0 auto;
}

/* 表单卡片 */
.form-card {
  margin: 0 32rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.05) 100%);
  backdrop-filter: blur(20rpx);
  border-radius: 36rpx;
  padding: 48rpx 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  position: relative;
  overflow: hidden;
}

/* 卡片顶部光效 */
.form-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.3) 50%, transparent 100%);
}

.form-group {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 20rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.form-label::before {
  content: '';
  width: 6rpx;
  height: 24rpx;
  background: linear-gradient(180deg, #FF6B8A 0%, #c44bff 100%);
  border-radius: 3rpx;
}

.optional-tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  font-weight: 400;
}

/* 性别选择 */
.gender-row {
  display: flex;
  gap: 20rpx;
}

.gender-opt {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.gender-opt::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 107, 138, 0.2) 0%, rgba(196, 75, 255, 0.2) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.gender-opt.active {
  background: rgba(255, 107, 138, 0.2);
  border-color: #FF6B8A;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 138, 0.4), inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
  transform: translateY(-2rpx);
}

.gender-opt.active::before {
  opacity: 1;
}

.gender-opt:active {
  transform: scale(0.98);
}

.gender-icon {
  font-size: 44rpx;
  position: relative;
  z-index: 1;
}

.gender-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
  position: relative;
  z-index: 1;
}

.gender-opt.active .gender-text {
  color: #fff;
  text-shadow: 0 0 10rpx rgba(255, 107, 138, 0.5);
}

/* 日期输入 */
.date-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.date-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  padding: 0 20rpx;
  height: 88rpx;
  transition: all 0.3s ease;
}

.date-input-wrap:focus-within {
  border-color: rgba(255, 107, 138, 0.5);
  background: rgba(255, 255, 255, 0.1);
  box-shadow: 0 0 20rpx rgba(255, 107, 138, 0.15);
}

.date-input {
  flex: 1;
  height: 88rpx;
  color: #fff;
  font-size: 32rpx;
  text-align: center;
  font-weight: 600;
  line-height: 88rpx;
  min-height: 88rpx;
}

.date-unit {
  font-size: 24rpx;
  color: rgba(255, 200, 220, 0.6);
  flex-shrink: 0;
  font-weight: 500;
}

/* 城市输入 */
.city-input-wrap {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  padding: 0 24rpx;
  height: 88rpx;
  transition: all 0.3s ease;
}

.city-input-wrap:focus-within {
  border-color: rgba(255, 107, 138, 0.5);
  background: rgba(255, 255, 255, 0.1);
  box-shadow: 0 0 20rpx rgba(255, 107, 138, 0.15);
}

.city-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  filter: drop-shadow(0 0 4rpx rgba(255, 200, 100, 0.5));
}

.city-input {
  flex: 1;
  height: 88rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 88rpx;
  min-height: 88rpx;
}

/* 提示 */
.form-tip {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: linear-gradient(135deg, rgba(180, 120, 255, 0.15) 0%, rgba(255, 107, 138, 0.1) 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-top: 8rpx;
  border: 1rpx solid rgba(180, 120, 255, 0.2);
}

.form-tip-icon { 
  font-size: 32rpx;
  filter: drop-shadow(0 0 6rpx rgba(180, 120, 255, 0.5));
}

.form-tip-text {
  font-size: 24rpx;
  color: rgba(220, 200, 255, 0.9);
  line-height: 1.7;
  flex: 1;
}

/* 生成按钮 */
.generate-btn {
  margin: 48rpx 32rpx 0;
  background: linear-gradient(135deg, #FF6B8A 0%, #c44bff 50%, #7b3fe4 100%);
  border-radius: 100rpx;
  padding: 38rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 
    0 8rpx 32rpx rgba(255, 107, 138, 0.4),
    0 4rpx 16rpx rgba(123, 63, 228, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

/* 按钮光效 */
.generate-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.3) 50%, transparent 100%);
  transition: left 0.5s ease;
}

.generate-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 138, 0.3);
}

.generate-btn-icon { 
  font-size: 44rpx;
  position: relative;
  z-index: 1;
  animation: sparkle 2s ease-in-out infinite;
}

@keyframes sparkle {
  0%, 100% { transform: scale(1) rotate(0deg); }
  50% { transform: scale(1.1) rotate(5deg); }
}

.generate-btn-text {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
  position: relative;
  z-index: 1;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.bottom-note {
  text-align: center;
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 0 40rpx;
}

.bottom-note text {
  font-size: 24rpx;
  color: rgba(255, 220, 255, 0.5);
  letter-spacing: 1rpx;
}

.bottom-note-sub {
  font-size: 22rpx;
  color: rgba(255, 200, 220, 0.4);
}

/* 客服入口 */
.support-section {
  margin-top: 36rpx;
  padding: 0 40rpx;
}

.support-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.05) 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 100rpx;
  padding: 26rpx 40rpx;
  transition: all 0.3s ease;
}

.support-btn:active {
  background: rgba(255, 255, 255, 0.15);
  transform: scale(0.98);
}

.support-icon {
  font-size: 32rpx;
}

.support-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.support-id {
  font-size: 24rpx;
  color: #ffd700;
  font-weight: 700;
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.2) 0%, rgba(255, 180, 0, 0.15) 100%);
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(255, 215, 0, 0.2);
}

/* ===== 步骤2：加载页 ===== */
.step-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
  position: relative;
  z-index: 1;
}

.loading-cosmos {
  width: 320rpx;
  height: 320rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
}

/* 中心光晕 */
.loading-cosmos::before {
  content: '';
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 107, 138, 0.3) 0%, transparent 70%);
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}

.cosmos-ring {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(180, 120, 255, 0.25);
  display: flex;
  align-items: flex-start;
  justify-content: center;
  box-shadow: 0 0 20rpx rgba(180, 120, 255, 0.1);
}

.ring1 { width: 200rpx; height: 200rpx; animation: spinCW 4s linear infinite; border-color: rgba(255, 107, 138, 0.4); }
.ring2 { width: 260rpx; height: 260rpx; animation: spinCCW 6s linear infinite; border-color: rgba(196, 75, 255, 0.35); }
.ring3 { width: 320rpx; height: 320rpx; animation: spinCW 10s linear infinite; border-color: rgba(123, 63, 228, 0.3); }

@keyframes spinCW {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes spinCCW {
  from { transform: rotate(0deg); }
  to { transform: rotate(-360deg); }
}

.orbit-star {
  font-size: 28rpx;
  display: block;
  margin-top: -14rpx;
}

.cosmos-center {
  font-size: 88rpx;
  position: absolute;
  animation: pulse 2s ease-in-out infinite;
  filter: drop-shadow(0 0 20rpx rgba(180, 120, 255, 0.6));
  z-index: 2;
}

.loading-text {
  font-size: 32rpx;
  color: rgba(220, 200, 255, 0.95);
  text-align: center;
  margin-bottom: 48rpx;
  min-height: 44rpx;
  animation: fadeIn 0.5s ease;
  font-weight: 500;
  letter-spacing: 2rpx;
  text-shadow: 0 0 20rpx rgba(180, 120, 255, 0.3);
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.loading-steps {
  display: flex;
  gap: 16rpx;
}

.ls-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transition: all 0.4s;
}

.ls-dot.done {
  background: #FF6B8A;
  box-shadow: 0 0 10rpx rgba(255, 107, 138, 0.8);
}

/* ===== 步骤3：结果页 ===== */
.step-result {
  padding: 0 0 40rpx;
  position: relative;
  z-index: 1;
}

/* 星盘徽章 */
.astro-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 48rpx 32rpx 32rpx;
}

.astro-tag {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.08);
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  min-width: 100rpx;
}

.at-symbol {
  font-size: 44rpx;
  filter: drop-shadow(0 0 8rpx rgba(255, 200, 100, 0.4));
}

.at-name {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  font-weight: 500;
}

.astro-divider {
  font-size: 32rpx;
  color: rgba(255, 107, 138, 0.9);
  margin-top: -8rpx;
  font-weight: 300;
}

.soulmate-tag {
  background: linear-gradient(135deg, rgba(255, 107, 138, 0.2) 0%, rgba(196, 75, 255, 0.2) 100%);
  border-color: rgba(255, 107, 138, 0.3);
}

.soulmate-tag .at-symbol {
  animation: heartbeat 1.5s ease-in-out infinite;
  filter: drop-shadow(0 0 12rpx rgba(255, 107, 138, 0.6));
}

@keyframes heartbeat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

/* 灵魂伴侣卡片 */
.soulmate-card {
  margin: 0 28rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.04) 100%);
  backdrop-filter: blur(20rpx);
  border-radius: 40rpx;
  padding: 52rpx 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  overflow: hidden;
  position: relative;
  box-shadow: 
    0 12rpx 40rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

.soulmate-card::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 30% 30%, rgba(255, 107, 138, 0.1) 0%, transparent 60%),
              radial-gradient(circle at 70% 70%, rgba(180, 80, 255, 0.1) 0%, transparent 60%);
  pointer-events: none;
}

/* 卡片顶部光效 */
.soulmate-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.25) 50%, transparent 100%);
}

.sm-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  text-align: center;
  margin-bottom: 16rpx;
  letter-spacing: 3rpx;
  text-shadow: 0 0 30rpx rgba(255, 107, 138, 0.5);
  background: linear-gradient(135deg, #fff 0%, #ffd4e5 50%, #e8d4ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.sm-subtitle {
  font-size: 26rpx;
  color: rgba(220, 180, 255, 0.9);
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.6;
  letter-spacing: 1rpx;
}

/* 头像区域 */
.avatar-zone {
  margin: 0 auto 48rpx;
  width: 340rpx;
  height: 340rpx;
  position: relative;
}

/* 头像外圈光晕 */
.avatar-zone::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 380rpx;
  height: 380rpx;
  background: radial-gradient(circle, rgba(255, 107, 138, 0.15) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

/* ===== 模糊头像：可见脸部轮廓版本 ===== */
.avatar-blur-wrap {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  /* 整体模糊，保留轮廓 */
  filter: blur(8px);
  box-shadow: 0 0 40rpx rgba(180, 100, 255, 0.4), 0 0 0 4rpx rgba(255,255,255,0.12);
}

.blur-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  position: relative;
  overflow: hidden;
}

/* 模糊头像图片（使用AI图片+强模糊） */
.blur-avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  /* 更强的模糊效果 - 几乎看不清细节 */
  filter: blur(25px) brightness(0.85) contrast(0.9);
  -webkit-filter: blur(25px) brightness(0.85) contrast(0.9);
}

/* 模糊渐变头像 - 预览状态 */
.blur-avatar-gradient {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  position: relative;
  overflow: hidden;
  /* 强模糊效果 - 几乎看不清细节 */
  filter: blur(25px) brightness(0.85) contrast(0.9);
  -webkit-filter: blur(25px) brightness(0.85) contrast(0.9);
}

.blur-hair {
  position: absolute;
  top: -10rpx;
  left: 20rpx;
  right: 20rpx;
  height: 130rpx;
  border-radius: 80rpx 80rpx 30rpx 30rpx;
  opacity: 0.95;
}

.blur-face {
  position: absolute;
  top: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 180rpx;
  height: 200rpx;
  border-radius: 50%;
}

/* 已解锁头像 - 清晰版本 */
.unlocked-avatar {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  position: relative;
  overflow: visible;
  border: 4rpx solid rgba(255, 215, 0, 0.6);
  box-shadow: 0 0 40rpx rgba(255, 107, 138, 0.5), 0 0 80rpx rgba(180, 80, 255, 0.3);
}

.ua-hair {
  position: absolute;
  top: -10rpx;
  left: 20rpx;
  right: 20rpx;
  height: 130rpx;
  border-radius: 80rpx 80rpx 30rpx 30rpx;
  opacity: 1;
}

.ua-face {
  position: absolute;
  top: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 180rpx;
  height: 200rpx;
  border-radius: 50%;
}

/* 发型（顶部） */
.bf-hair {
  position: absolute;
  border-radius: 50%;
}

.bf-hair-top {
  top: -12rpx;
  left: 20rpx;
  right: 20rpx;
  height: 140rpx;
  border-radius: 80rpx 80rpx 30rpx 30rpx;
  opacity: 0.92;
}

.bf-hair-left {
  top: 40rpx;
  left: -8rpx;
  width: 60rpx;
  height: 130rpx;
  border-radius: 40rpx;
  opacity: 0.85;
}

.bf-hair-right {
  top: 40rpx;
  right: -8rpx;
  width: 60rpx;
  height: 130rpx;
  border-radius: 40rpx;
  opacity: 0.85;
}

/* 脸部轮廓 */
.bf-face-shape {
  position: absolute;
  top: 80rpx;
  left: 48rpx;
  right: 48rpx;
  height: 190rpx;
  border-radius: 50% 50% 45% 45% / 40% 40% 60% 60%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 24rpx;
  gap: 0;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}

/* 眼睛区域 */
.bf-eyes-row {
  display: flex;
  justify-content: space-around;
  width: 100%;
  padding: 0 16rpx;
  margin-bottom: 18rpx;
}

.bf-eye-wrap {
  position: relative;
  width: 44rpx;
  height: 32rpx;
}

.bf-eye-white {
  width: 44rpx;
  height: 28rpx;
  background: rgba(255,255,255,0.9);
  border-radius: 50%;
  position: absolute;
  bottom: 0;
}

.bf-eye-pupil {
  width: 20rpx;
  height: 20rpx;
  background: rgba(40, 20, 60, 0.85);
  border-radius: 50%;
  position: absolute;
  bottom: 4rpx;
  left: 12rpx;
}

.bf-eyebrow {
  width: 40rpx;
  height: 8rpx;
  background: rgba(40, 20, 60, 0.6);
  border-radius: 4rpx;
  position: absolute;
  top: 0;
  left: 2rpx;
  transform: rotate(-3deg);
}

/* 鼻子 */
.bf-nose-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 14rpx;
}

.bf-nose-bridge {
  width: 8rpx;
  height: 26rpx;
  background: rgba(0,0,0,0.12);
  border-radius: 4rpx;
  margin-bottom: 4rpx;
}

.bf-nose-tip {
  width: 28rpx;
  height: 14rpx;
  background: rgba(0,0,0,0.12);
  border-radius: 50%;
}

/* 嘴巴 */
.bf-mouth-area {
  display: flex;
  align-items: center;
  justify-content: center;
}

.bf-lips {
  width: 52rpx;
  height: 20rpx;
  background: rgba(200, 80, 100, 0.65);
  border-radius: 0 0 52rpx 52rpx;
  position: relative;
}

.bf-lips::before {
  content: '';
  position: absolute;
  top: 0;
  left: 4rpx;
  right: 4rpx;
  height: 10rpx;
  background: rgba(220, 100, 120, 0.5);
  border-radius: 50%;
}

/* 轻度模糊遮罩（透明，只保留轻微色彩柔化） */
.blur-overlay-light {
  position: absolute;
  inset: 0;
  background: rgba(80, 40, 120, 0.18);
  border-radius: 50%;
}

/* 解锁提示：底部条样式（不遮挡脸部） */
.unlock-mask-light {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  pointer-events: none;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
}

.um-bottom-bar {
  width: 100%;
  background: linear-gradient(to top, rgba(10, 5, 30, 0.82) 0%, rgba(10, 5, 30, 0.5) 60%, transparent 100%);
  border-radius: 0 0 50% 50%;
  padding: 14rpx 0 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}

.um-lock-small { font-size: 28rpx; }

.um-title-small {
  font-size: 18rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.um-price-small {
  font-size: 26rpx;
  font-weight: 700;
  color: #ffd700;
  text-shadow: 0 0 8rpx rgba(255,215,0,0.7);
}

/* 已解锁头像 */
.avatar-unlocked-wrap {
  width: 320rpx;
  height: 320rpx;
  position: relative;
}

.unlocked-image {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 215, 0, 0.6);
  box-shadow: 0 0 40rpx rgba(255, 107, 138, 0.5), 0 0 80rpx rgba(180, 80, 255, 0.3);
}

.unlocked-badge {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #ffd700, #ff9500);
  border-radius: 100rpx;
  padding: 8rpx 24rpx;
  font-size: 20rpx;
  color: #fff;
  white-space: nowrap;
  box-shadow: 0 4rpx 16rpx rgba(255, 180, 0, 0.4);
}

.longpress-hint {
  text-align: center;
  margin-top: 16rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 描述文字 */
.sm-desc-wrap {
  position: relative;
  padding: 0 20rpx;
  margin-bottom: 40rpx;
}

.sm-desc-quote {
  font-size: 80rpx;
  color: rgba(180, 100, 255, 0.4);
  line-height: 0.5;
  font-family: Georgia, serif;
  position: absolute;
  top: -10rpx;
  left: 10rpx;
}

.end-quote {
  bottom: -20rpx;
  top: auto;
  right: 10rpx;
  left: auto;
}

.sm-desc {
  font-size: 30rpx;
  color: rgba(255, 220, 255, 0.92);
  line-height: 1.8;
  text-align: center;
  padding: 20rpx 40rpx;
  font-style: italic;
}

/* 星盘详情 */
.astro-detail {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.ad-item {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}

.ad-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.45);
  margin-bottom: 8rpx;
}

.ad-value {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

.ad-highlight {
  color: #FF6B8A !important;
}

/* 底部按钮组 */
.result-actions {
  margin: 32rpx 28rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ===== 支付区域样式 ===== */
.pay-section {
  background: linear-gradient(145deg, rgba(255, 107, 138, 0.15) 0%, rgba(123, 63, 228, 0.15) 100%);
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  border: 2rpx solid rgba(255, 107, 138, 0.3);
  box-shadow: 0 8rpx 40rpx rgba(200, 80, 255, 0.2);
}

.pay-section-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.pay-section-icon {
  font-size: 40rpx;
}

.pay-section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

/* 价格展示 */
.pay-price-wrap {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4rpx;
  margin-bottom: 32rpx;
}

.pay-price-currency {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffd700;
}

.pay-price-value {
  font-size: 72rpx;
  font-weight: 900;
  color: #ffd700;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.5);
  line-height: 1;
}

.pay-price-unit {
  font-size: 28rpx;
  color: rgba(255, 215, 0, 0.8);
  margin-left: 4rpx;
}

/* 权益说明 */
.pay-benefits {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 32rpx;
}

.pay-benefit-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.pay-benefit-item:last-child {
  border-bottom: none;
}

.pay-benefit-icon {
  font-size: 28rpx;
  width: 40rpx;
  text-align: center;
}

.pay-benefit-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 收款二维码区域 */
.pay-qr-section {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.05) 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

.pay-qr-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  margin-bottom: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.pay-qr-wrap {
  width: 400rpx;
  height: 500rpx;
  margin: 0 auto;
  background: #fff;
  border-radius: 20rpx;
  padding: 16rpx;
  position: relative;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  overflow: hidden;
}

.pay-qr-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

/* 点击放大提示遮罩 */
.pay-qr-click-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.pay-qr-wrap:active .pay-qr-click-mask {
  opacity: 1;
}

.pay-qr-click-text {
  font-size: 28rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.6);
  padding: 16rpx 32rpx;
  border-radius: 100rpx;
  font-weight: 600;
}

/* 二维码光效动画 */
.pay-qr-shine {
  position: absolute;
  top: 0;
  left: -100%;
  width: 50%;
  height: 100%;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.4) 50%, transparent 100%);
  animation: qrShine 3s ease-in-out infinite;
  pointer-events: none;
}

@keyframes qrShine {
  0% { left: -100%; }
  50% { left: 150%; }
  100% { left: 150%; }
}

.pay-qr-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 24rpx;
  padding: 16rpx 24rpx;
  background: rgba(255, 215, 0, 0.1);
  border-radius: 100rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.2);
}

.pay-qr-hint-icon {
  font-size: 28rpx;
}

.pay-qr-hint-text {
  font-size: 24rpx;
  color: rgba(255, 215, 0, 0.9);
  font-weight: 500;
}

/* 支付步骤 */
.pay-qr-steps, .pay-link-steps {
  margin-top: 24rpx;
  padding: 24rpx;
  background: rgba(0, 0, 0, 0.15);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.pay-step {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
}

.pay-step-num {
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #FF6B8A 0%, #7B3FE4 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
  flex-shrink: 0;
}

.pay-step-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.4;
}

.pay-step-arrow {
  text-align: center;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  padding: 8rpx 0;
  margin-left: 10rpx;
}

/* 分割线 */
.pay-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin: 32rpx 0;
}

.pay-divider-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.3) 50%, transparent 100%);
}

.pay-divider-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

/* 链接付款方式 */
.pay-link-section {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.04) 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.pay-link-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  margin-bottom: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.pay-link-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, rgba(255, 107, 138, 0.2) 0%, rgba(123, 63, 228, 0.2) 100%);
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  border: 2rpx solid rgba(255, 107, 138, 0.3);
  transition: all 0.3s ease;
}

.pay-link-card:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, rgba(255, 107, 138, 0.3) 0%, rgba(123, 63, 228, 0.3) 100%);
}

.pay-link-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.pay-link-icon {
  font-size: 36rpx;
}

.pay-link-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

.pay-link-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 300;
}

.pay-link-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 16rpx 24rpx;
  background: rgba(255, 215, 0, 0.08);
  border-radius: 100rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.15);
}

.pay-link-hint-icon {
  font-size: 24rpx;
}

.pay-link-hint-text {
  font-size: 24rpx;
  color: rgba(255, 215, 0, 0.8);
  font-weight: 500;
}

/* 支付验证区域 */
.pay-verify-section {
  background: linear-gradient(145deg, rgba(255, 215, 0, 0.08) 0%, rgba(255, 215, 0, 0.04) 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 32rpx 0;
  border: 1rpx solid rgba(255, 215, 0, 0.15);
}

.pay-verify-title {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 30rpx;
  color: rgba(255, 215, 0, 0.95);
  font-weight: 600;
  margin-bottom: 16rpx;
}

.pay-verify-icon {
  font-size: 32rpx;
}

.pay-verify-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: center;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.pay-verify-requirements {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}

.req-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.8;
}

.pay-verify-warning {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 107, 138, 0.1);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 107, 138, 0.2);
}

.warning-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.warning-text {
  font-size: 22rpx;
  color: rgba(255, 107, 138, 0.9);
  line-height: 1.4;
}

/* 上传截图按钮 */
.upload-screenshot-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx dashed rgba(255, 215, 0, 0.4);
  border-radius: 20rpx;
  padding: 48rpx 32rpx;
  transition: all 0.3s ease;
}

.upload-screenshot-btn:active {
  background: rgba(255, 215, 0, 0.1);
  border-color: rgba(255, 215, 0, 0.6);
}

.upload-icon {
  font-size: 60rpx;
  color: rgba(255, 215, 0, 0.8);
  font-weight: 300;
}

.upload-text {
  font-size: 28rpx;
  color: rgba(255, 215, 0, 0.9);
  font-weight: 500;
}

.upload-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
}

/* 截图预览 */
.screenshot-preview {
  background: rgba(0, 0, 0, 0.2);
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.screenshot-image {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.3);
}

.screenshot-actions {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-top: 20rpx;
}

.screenshot-replace, .screenshot-delete {
  font-size: 26rpx;
  color: rgba(255, 215, 0, 0.9);
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  background: rgba(255, 215, 0, 0.1);
}

.screenshot-delete {
  color: rgba(255, 107, 107, 0.9);
  background: rgba(255, 107, 107, 0.1);
}

/* 支付按钮禁用状态 */
.paid-btn-disabled {
  opacity: 0.5;
  background: linear-gradient(135deg, #999 0%, #666 100%) !important;
}

/* 待审核状态 */
.pay-pending-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
  background: rgba(255, 215, 0, 0.08);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.3);
  margin-bottom: 24rpx;
}

.pay-pending-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.pay-pending-title {
  font-size: 32rpx;
  font-weight: bold;
  color: rgba(255, 215, 0, 0.95);
  margin-bottom: 16rpx;
}

.pay-pending-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.pay-pending-tip {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  text-align: center;
}

/* 支付提示 */
.pay-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 215, 0, 0.1);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.2);
}

.pay-tip-icon {
  font-size: 24rpx;
}

.pay-tip-text {
  font-size: 24rpx;
  color: rgba(255, 215, 0, 0.9);
}

/* 我已支付按钮 */
.paid-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 100rpx;
  padding: 28rpx 0;
  active-opacity: 0.85;
}

.paid-btn.primary {
  background: linear-gradient(135deg, #FF6B8A 0%, #7B3FE4 100%);
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 138, 0.4);
}

.paid-btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.paid-btn-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

.paid-btn.primary .paid-btn-text {
  color: #fff;
}

/* 备用方式 */
.pay-alternative {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 24rpx;
  padding: 16rpx 0;
}

.pay-alt-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.pay-alt-link {
  font-size: 26rpx;
  color: #FF6B8A;
  text-decoration: underline;
}

/* 已解锁操作按钮 */
.unlocked-actions {
  display: flex;
  gap: 20rpx;
}

.ua-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  line-height: normal;
}

.ua-share-btn {
  background: linear-gradient(135deg, rgba(255, 107, 138, 0.3), rgba(180, 80, 255, 0.3));
  border-color: rgba(255, 107, 138, 0.5);
}

.ua-icon { font-size: 32rpx; }

/* 重新测算 */
.regen-btn {
  text-align: center;
  padding: 24rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.45);
}

/* AI生成免责声明 */
.ai-disclaimer {
  margin: 20rpx 28rpx 0;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.ai-disclaimer-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
  text-align: center;
