/* pages/quiz/quiz.wxss */
.quiz-page { background: #f8f8fc; min-height: 100vh; }

/* 封面 */
.quiz-cover { }
.cover-bg {
  padding: 80rpx 32rpx 60rpx;
  text-align: center;
}
.cover-emoji { font-size: 88rpx; display: block; margin-bottom: 16rpx; }
.cover-title { font-size: 44rpx; font-weight: 800; color: #fff; margin-bottom: 8rpx; }
.cover-sub { font-size: 26rpx; color: rgba(255,255,255,0.85); }

.cover-body { padding: 24rpx; }
.quiz-type-list { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 32rpx; }
.quiz-type-card {
  display: flex; align-items: center; padding: 28rpx;
  background: #fff; border-radius: 20rpx; gap: 20rpx;
  border: 3rpx solid transparent;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.07);
}
.quiz-type-card.selected { border-color: #FF6B8A; background: #fff9fb; }
.qtc-icon { font-size: 48rpx; flex-shrink: 0; }
.qtc-info { flex: 1; }
.qtc-name { font-size: 30rpx; font-weight: 700; color: #1a1a2e; margin-bottom: 4rpx; }
.qtc-desc { font-size: 24rpx; color: #999; }
.qtc-check { color: #FF6B8A; font-size: 32rpx; font-weight: 700; }
.start-btn { margin: 0; }

/* 做题 */
.quiz-doing { padding: 24rpx; min-height: 100vh; background: #f8f8fc; }
.q-progress-bar { display: flex; align-items: center; gap: 16rpx; margin-bottom: 32rpx; }
.q-progress-bg { flex: 1; height: 12rpx; background: #e5e7eb; border-radius: 100rpx; overflow: hidden; }
.q-progress-fill { height: 100%; background: linear-gradient(90deg, #FF6B8A, #FF8E53); border-radius: 100rpx; transition: width 0.4s; }
.q-progress-text { font-size: 24rpx; color: #999; flex-shrink: 0; }

.q-card { background: #fff; border-radius: 20rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.07); }
.q-num { font-size: 22rpx; color: #FF6B8A; font-weight: 600; margin-bottom: 12rpx; }
.q-text { font-size: 32rpx; font-weight: 700; color: #1a1a2e; line-height: 1.6; }

.q-options { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 32rpx; }
.q-option {
  display: flex; align-items: center; padding: 24rpx;
  background: #fff; border-radius: 16rpx; gap: 16rpx;
  border: 2rpx solid #f0f0f0;
  transition: all 0.2s;
}
.q-option.selected { border-color: #FF6B8A; background: #fff9fb; }
.q-opt-radio {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  border: 3rpx solid #ddd; flex-shrink: 0;
}
.q-opt-radio.checked {
  border-color: #FF6B8A;
  background: #FF6B8A;
  box-shadow: inset 0 0 0 6rpx #fff;
}
.q-opt-text { font-size: 28rpx; color: #1a1a2e; line-height: 1.5; flex: 1; }

.q-next-btn {
  text-align: center; padding: 28rpx;
  border-radius: 100rpx; font-size: 30rpx; font-weight: 600;
  background: #e0e0e0; color: #999;
}
.q-next-btn.active { background: #FF6B8A; color: #fff; }
.q-next-btn.disabled { opacity: 0.6; }

/* 结果页 */
.result-header { padding: 60rpx 32rpx 48rpx; text-align: center; }
.result-emoji { font-size: 96rpx; display: block; margin-bottom: 16rpx; }
.result-type { font-size: 44rpx; font-weight: 800; color: #fff; margin-bottom: 8rpx; }
.result-tagline { font-size: 26rpx; color: rgba(255,255,255,0.9); }

.result-body { padding: 24rpx; }
.result-section { margin-bottom: 24rpx; }
.rs-title { font-size: 30rpx; font-weight: 700; color: #1a1a2e; margin-bottom: 16rpx; }
.rs-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.rs-tag {
  background: #FFE8EE; color: #FF6B8A;
  font-size: 24rpx; padding: 8rpx 20rpx; border-radius: 100rpx;
}
.rs-text { font-size: 28rpx; color: #444; line-height: 1.8; white-space: pre-wrap; }

.result-row { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.result-half { flex: 1; padding: 24rpx; }
.rh-icon { font-size: 40rpx; margin-bottom: 10rpx; }
.rh-title { font-size: 26rpx; font-weight: 700; color: #1a1a2e; margin-bottom: 10rpx; }
.rh-item { font-size: 24rpx; color: #666; line-height: 1.8; }

.rs-advice { display: flex; flex-direction: column; gap: 16rpx; }
.rs-advice view { display: flex; align-items: flex-start; gap: 16rpx; }
.advice-num {
  width: 44rpx; height: 44rpx; background: #FFE8EE; color: #FF6B8A;
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; font-weight: 700; flex-shrink: 0;
}
.advice-text { font-size: 28rpx; color: #1a1a2e; line-height: 1.6; flex: 1; }

.result-actions { display: flex; gap: 16rpx; margin-top: 32rpx; padding-bottom: 60rpx; }
.result-actions .btn-outline, .result-actions .btn-primary { flex: 1; }
