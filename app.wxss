/* app.wxss - 全局样式（现代配色优化版）*/

page {
  background-color: #f8f8fc;
  color: #000000;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 30rpx;
  line-height: 1.6;
  /* CSS变量定义（高版本基础库支持） */
  --primary: #FF6B8A;
  --primary-light: #FFE8EE;
  --primary-dark: #E85A7A;
  --secondary: #6C63FF;
  --secondary-light: #E8E6FF;
  --accent: #FF8E53;
  --text-main: #000000;
  --text-sub: #333333;
  --text-hint: #666666;
  --bg: #f8f8fc;
  --bg-card: #ffffff;
  --white: #ffffff;
  --radius: 16rpx;
  --radius-lg: 24rpx;
  --shadow-sm: 0 2rpx 12rpx rgba(0,0,0,0.06);
  --shadow-md: 0 4rpx 20rpx rgba(0,0,0,0.08);
  --shadow-primary: 0 4rpx 20rpx rgba(255, 107, 138, 0.25);
}

/* 通用卡片 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  overflow: hidden;
}

/* 玻璃拟态卡片 */
.card-glass {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.05);
}

/* 渐变背景 */
.gradient-bg {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8E53 100%);
}
.gradient-bg-purple {
  background: linear-gradient(135deg, #6C63FF 0%, #a78bfa 100%);
}
.gradient-bg-teal {
  background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%);
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tag-pink { background: #FFE8EE; color: #FF6B8A; }
.tag-purple { background: #ede9fe; color: #6C63FF; }
.tag-green { background: #dcfce7; color: #16a34a; }
.tag-blue { background: #dbeafe; color: #2563eb; }

/* 按钮 */
.btn-primary {
  background: #FF6B8A;
  color: #ffffff;
  border-radius: 100rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  display: block;
  box-sizing: border-box;
}
.btn-outline {
  background: transparent;
  color: #FF6B8A;
  border: 2rpx solid #FF6B8A;
  border-radius: 100rpx;
  padding: 22rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  display: block;
  box-sizing: border-box;
}
.btn-primary-sm {
  background: #FF6B8A;
  color: #ffffff;
  border-radius: 100rpx;
  padding: 14rpx 32rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  display: inline-block;
}

/* ===== 通用输入框样式 ===== */
.input-field {
  width: 100%;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  color: #1a1a2e;
  background: #fafafa;
  box-sizing: border-box;
  line-height: 1.5;
}

.input-field::placeholder {
  color: #999999;
}

.input-field-focus {
  border-color: #FF6B8A;
  background: #fff;
}

/* section 标题 */
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #000000;
  margin-bottom: 24rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* flex工具类 */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.justify-center { justify-content: center; }
.flex-1 { flex: 1; }

/* 间距 */
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.p-24 { padding: 24rpx; }
.p-32 { padding: 32rpx; }

/* 分割线 */
.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 0;
}

/* 通用弹层结构 */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.modal-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
}
.modal-sheet {
  position: relative;
  z-index: 1000;
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}
.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}
.modal-close {
  width: 48rpx;
  height: 48rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666666;
}
.modal-scrollbody {
  flex: 1;
  overflow: hidden;
}
.modal-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}
