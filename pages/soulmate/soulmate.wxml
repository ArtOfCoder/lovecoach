<!-- pages/soulmate/soulmate.wxml - 星座配对（全面升级版） -->
<view class="soulmate-page">

  <!-- ========== 步骤1：输入页 ========== -->
  <view wx:if="{{step === 'input'}}" class="step-input">

    <!-- 头部 -->
    <view class="input-header">
      <view class="input-header-bg"></view>
      <view class="input-zodiac-row">
        <text class="iz-symbol">♈</text>
        <text class="iz-symbol">♉</text>
        <text class="iz-symbol">♊</text>
        <text class="iz-symbol">♋</text>
        <text class="iz-symbol">♌</text>
        <text class="iz-symbol">♍</text>
      </view>
      <view class="input-title-wrap">
        <view class="input-title">星座配对测试</view>
        <view class="input-subtitle">探索你与TA的星座缘分指数</view>
      </view>
      <view class="input-zodiac-row">
        <text class="iz-symbol">♎</text>
        <text class="iz-symbol">♏</text>
        <text class="iz-symbol">♐</text>
        <text class="iz-symbol">♑</text>
        <text class="iz-symbol">♒</text>
        <text class="iz-symbol">♓</text>
      </view>
    </view>

    <!-- 表单卡片 -->
    <view class="form-card">

      <!-- 我是 -->
      <view class="form-group">
        <view class="form-label">
          <text class="form-label-icon">👤</text>
          <text>我是</text>
        </view>
        <view class="gender-row">
          <view
            class="gender-opt {{userGender === 'male' ? 'active' : ''}}"
            bindtap="selectGender"
            data-gender="male"
          >
            <text class="gender-icon">👦</text>
            <text class="gender-text">男生</text>
          </view>
          <view
            class="gender-opt {{userGender === 'female' ? 'active' : ''}}"
            bindtap="selectGender"
            data-gender="female"
          >
            <text class="gender-icon">👧</text>
            <text class="gender-text">女生</text>
          </view>
        </view>
      </view>

      <!-- 出生日期 -->
      <view class="form-group">
        <view class="form-label">
          <text class="form-label-icon">🗓</text>
          <text>出生日期</text>
        </view>
        <view class="date-row">
          <view class="date-input-wrap">
            <input
              class="date-input"
              type="number"
              placeholder="年"
              placeholder-style="color:rgba(255,255,255,0.4);font-size:26rpx;"
              maxlength="4"
              value="{{birthYear}}"
              bindinput="onBirthYearInput"
              confirm-type="next"
            />
            <text class="date-unit">年</text>
          </view>
          <view class="date-input-wrap">
            <input
              class="date-input"
              type="number"
              placeholder="月"
              placeholder-style="color:rgba(255,255,255,0.4);font-size:26rpx;"
              maxlength="2"
              value="{{birthMonth}}"
              bindinput="onBirthMonthInput"
              confirm-type="next"
            />
            <text class="date-unit">月</text>
          </view>
          <view class="date-input-wrap">
            <input
              class="date-input"
              type="number"
              placeholder="日"
              placeholder-style="color:rgba(255,255,255,0.4);font-size:26rpx;"
              maxlength="2"
              value="{{birthDay}}"
              bindinput="onBirthDayInput"
              confirm-type="done"
            />
            <text class="date-unit">日</text>
          </view>
        </view>
      </view>

      <!-- 出生地 -->
      <view class="form-group">
        <view class="form-label">
          <text class="form-label-icon">📍</text>
          <text>出生城市 <text class="optional-tag">（可选）</text></text>
        </view>
        <view class="city-input-wrap">
          <input
            class="city-input"
            type="text"
            placeholder="如：北京、上海（影响上升星座计算）"
            placeholder-style="color:rgba(255,255,255,0.4);font-size:24rpx;"
            value="{{birthCity}}"
            bindinput="onBirthCityInput"
          />
        </view>
      </view>

    </view>

    <!-- 生成按钮 -->
    <view class="generate-btn" bindtap="startGenerate">
      <text class="generate-btn-icon">✨</text>
      <text class="generate-btn-text">开始星座配对</text>
    </view>

    <!-- 免责声明 -->
    <view class="input-footer">
      <text class="input-footer-text">基于星座知识库分析，结果仅供娱乐参考</text>
    </view>

  </view>

  <!-- ========== 步骤2：加载中 ========== -->
  <view wx:if="{{step === 'loading'}}" class="step-loading">
    <view class="loading-cosmos">
      <view class="cosmos-orbit orbit1">
        <view class="orbit-planet p1">♈</view>
      </view>
      <view class="cosmos-orbit orbit2">
        <view class="orbit-planet p2">💕</view>
      </view>
      <view class="cosmos-orbit orbit3">
        <view class="orbit-planet p3">♎</view>
      </view>
      <view class="cosmos-core">✨</view>
    </view>
    <view class="loading-title">正在分析星座配对</view>
    <view class="loading-text">{{loadingText}}</view>
    <view class="loading-steps">
      <view class="ls-dot {{loadingStep >= 0 ? 'done' : ''}}"></view>
      <view class="ls-dot {{loadingStep >= 1 ? 'done' : ''}}"></view>
      <view class="ls-dot {{loadingStep >= 2 ? 'done' : ''}}"></view>
      <view class="ls-dot {{loadingStep >= 3 ? 'done' : ''}}"></view>
      <view class="ls-dot {{loadingStep >= 4 ? 'done' : ''}}"></view>
    </view>
  </view>

  <!-- ========== 步骤3：结果页 ========== -->
  <view wx:if="{{step === 'result'}}" class="step-result">

    <!-- 顶部渐变头图 -->
    <view class="result-hero">
      <view class="result-hero-bg"></view>
      <view class="rh-zodiac-info">
        <view class="rh-my-zodiac">
          <view class="rhz-symbol">{{astroSummary.zodiac.symbol}}</view>
          <view class="rhz-name">{{astroSummary.zodiac.name}}</view>
          <view class="rhz-label">我的星座</view>
        </view>
        <view class="rh-heart-divider">
          <text class="rh-heart">💖</text>
          <view class="rh-compat-score">{{compatScore}}%</view>
          <view class="rh-compat-label">契合度</view>
        </view>
        <view class="rh-soulmate-zodiac">
          <view class="rhz-symbol soulmate-color">{{soulmateSymbol}}</view>
          <view class="rhz-name">{{astroSummary.soulmateZodiac}}</view>
          <view class="rhz-label">最佳配对</view>
        </view>
      </view>
    </view>

    <!-- 配对人物双卡 -->
    <view class="couple-cards-wrap">
      <view class="couple-card my-card">
        <view class="cc-label-tag my-tag">我</view>
        <image
          wx:if="{{myAvatarUrl}}"
          class="cc-avatar"
          src="{{myAvatarUrl}}"
          mode="aspectFill"
          bindlongpress="onLongPressImage"
        />
        <view wx:else class="cc-avatar-placeholder" style="background:{{myAvatarGradient}};">
          <text>{{astroSummary.zodiac.symbol}}</text>
        </view>
        <view class="cc-zodiac-name">{{astroSummary.zodiac.name}}</view>
        <view class="cc-zodiac-keyword">{{myZodiacKeyword}}</view>
      </view>

      <view class="couple-match-center">
        <view class="match-ring">
          <text class="match-ring-text">{{compatLevel}}</text>
        </view>
        <view class="match-stars">{{matchStars}}</view>
      </view>

      <view class="couple-card soulmate-card-new">
        <view class="cc-label-tag soulmate-tag-new">TA</view>
        <image
          wx:if="{{soulmate.imageUrl}}"
          class="cc-avatar"
          src="{{soulmate.imageUrl}}"
          mode="aspectFill"
          bindlongpress="onLongPressImage"
        />
        <view wx:else class="cc-avatar-placeholder" style="background:{{soulmate.avatarStyle}};">
          <text>{{soulmateSymbol}}</text>
        </view>
        <view class="cc-zodiac-name">{{astroSummary.soulmateZodiac}}</view>
        <view class="cc-zodiac-keyword">{{soulmateKeyword}}</view>
      </view>
    </view>

    <!-- 配对详情卡片 -->
    <view class="result-detail-card">

      <!-- 星盘信息行 -->
      <view class="astro-info-row">
        <view class="air-item">
          <view class="air-icon">☀️</view>
          <view class="air-content">
            <view class="air-label">太阳星座</view>
            <view class="air-value">{{astroSummary.zodiac.name}}</view>
          </view>
        </view>
        <view class="air-item">
          <view class="air-icon">↑</view>
          <view class="air-content">
            <view class="air-label">上升星座</view>
            <view class="air-value">{{astroSummary.ascendant}}</view>
          </view>
        </view>
        <view class="air-item">
          <view class="air-icon">🌙</view>
          <view class="air-content">
            <view class="air-label">月亮星座</view>
            <view class="air-value">{{astroSummary.moonSign}}</view>
          </view>
        </view>
      </view>

      <!-- 分割线 -->
      <view class="divider-line"></view>

      <!-- 配对描述 -->
      <view class="compat-desc-wrap">
        <view class="cdw-title">
          <text class="cdw-icon">💬</text>
          <text>配对解析</text>
        </view>
        <view class="cdw-text">{{soulmate.desc}}</view>
      </view>

      <!-- 四维契合度 -->
      <view class="compat-bars-wrap">
        <view class="cbw-title">
          <text class="cbw-icon">📊</text>
          <text>四维契合度</text>
        </view>
        <view class="compat-bar-item" wx:for="{{compatDimensions}}" wx:key="label">
          <view class="cbi-label">{{item.label}}</view>
          <view class="cbi-track">
            <view class="cbi-fill" style="width:{{item.value}}%;background:{{item.color}};"></view>
          </view>
          <view class="cbi-value">{{item.value}}</view>
        </view>
      </view>

      <!-- 优劣势分析 -->
      <view class="pro-con-wrap">
        <view class="pc-col">
          <view class="pc-title pros">💚 优势</view>
          <view class="pc-item" wx:for="{{compatPros}}" wx:key="*this">
            <text class="pc-dot">·</text>
            <text>{{item}}</text>
          </view>
        </view>
        <view class="pc-col">
          <view class="pc-title cons">🔶 注意</view>
          <view class="pc-item" wx:for="{{compatCons}}" wx:key="*this">
            <text class="pc-dot">·</text>
            <text>{{item}}</text>
          </view>
        </view>
      </view>

    </view>

    <!-- 底部操作 -->
    <view class="result-actions">
      <view class="ra-btn save-btn" bindtap="saveImage">
        <text class="ra-icon">📥</text>
        <text class="ra-text">保存图片</text>
      </view>
      <button class="ra-btn share-btn" open-type="share">
        <text class="ra-icon">💌</text>
        <text class="ra-text">分享好友</text>
      </button>
    </view>

    <view class="retest-btn" bindtap="goBack">
      <text>🔄 重新测试</text>
    </view>

    <!-- 免责声明 -->
    <view class="result-disclaimer">
      <text>基于星座知识库生成，仅供娱乐参考，不代表真实建议</text>
    </view>

  </view>

</view>
