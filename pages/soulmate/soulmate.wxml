<!-- pages/soulmate/soulmate.wxml - 星座配对 -->
<view class="soulmate-page">

  <!-- ========== 步骤1：输入页 ========== -->
  <view wx:if="{{step === 'input'}}" class="step-input">

    <!-- 头部装饰 -->
    <view class="header-deco">
      <view class="star-ring">
        <text class="big-star">✨</text>
        <text class="zodiac-float z1">♈</text>
        <text class="zodiac-float z2">♋</text>
        <text class="zodiac-float z3">♎</text>
        <text class="zodiac-float z4">♑</text>
      </view>
      <view class="header-title">星座配对测试</view>
      <view class="header-sub">输入生日，探索你的星座性格与最佳配对</view>
    </view>

    <!-- 表单卡片 -->
    <view class="form-card">

      <!-- 性别选择 -->
      <view class="form-group">
        <view class="form-label">我是</view>
        <view class="gender-row">
          <view
            class="gender-opt {{userGender === 'male' ? 'active' : ''}}"
            bindtap="selectGender"
            data-gender="male"
          >
            <text class="gender-icon">👦</text>
            <text class="gender-text">男生</text>
          </view>
          <view
            class="gender-opt {{userGender === 'female' ? 'active' : ''}}"
            bindtap="selectGender"
            data-gender="female"
          >
            <text class="gender-icon">👧</text>
            <text class="gender-text">女生</text>
          </view>
        </view>
      </view>

      <!-- 出生日期 -->
      <view class="form-group">
        <view class="form-label">出生日期</view>
        <view class="date-row">
          <view class="date-input-wrap">
            <input
              class="date-input"
              type="number"
              placeholder="年"
              placeholder-style="color:rgba(255,255,255,0.35);font-size:28rpx;"
              maxlength="4"
              value="{{birthYear}}"
              bindinput="onBirthYearInput"
              confirm-type="next"
            />
            <text class="date-unit">年</text>
          </view>
          <view class="date-input-wrap">
            <input
              class="date-input"
              type="number"
              placeholder="月"
              placeholder-style="color:rgba(255,255,255,0.35);font-size:28rpx;"
              maxlength="2"
              value="{{birthMonth}}"
              bindinput="onBirthMonthInput"
              confirm-type="next"
            />
            <text class="date-unit">月</text>
          </view>
          <view class="date-input-wrap">
            <input
              class="date-input"
              type="number"
              placeholder="日"
              placeholder-style="color:rgba(255,255,255,0.35);font-size:28rpx;"
              maxlength="2"
              value="{{birthDay}}"
              bindinput="onBirthDayInput"
              confirm-type="done"
            />
            <text class="date-unit">日</text>
          </view>
        </view>
      </view>

      <!-- 出生地 -->
      <view class="form-group">
        <view class="form-label">出生城市 <text class="optional-tag">（可选）</text></view>
        <view class="city-input-wrap">
          <text class="city-icon">📍</text>
          <input
            class="city-input"
            type="text"
            placeholder="如：北京、上海（影响上升星座）"
            placeholder-style="color:rgba(255,255,255,0.35);font-size:24rpx;"
            value="{{birthCity}}"
            bindinput="onBirthCityInput"
          />
        </view>
      </view>

      <!-- 说明文字 -->
      <view class="form-tip">
        <text class="form-tip-icon">⭐</text>
        <text class="form-tip-text">根据你的生日分析太阳星座、月亮星座和上升星座，探索与你最契合的伴侣星座特质</text>
      </view>

    </view>

    <!-- 生成按钮 -->
    <view class="generate-btn" bindtap="startGenerate">
      <text class="generate-btn-icon">💫</text>
      <text class="generate-btn-text">开始星座配对分析</text>
    </view>

    <!-- 底部说明 -->
    <view class="bottom-note">
      <text>免费查看你的星座配对结果</text>
      <text class="bottom-note-sub">基于星座运势的娱乐测试，仅供参考</text>
    </view>
    
    <!-- 免责声明 -->
    <view class="ai-disclaimer">
      <text class="ai-disclaimer-text">本功能基于星座知识库生成，仅供娱乐参考，不代表任何真实建议</text>
    </view>

    <!-- 客服入口 -->
    <view class="support-section">
      <view class="support-btn" bindtap="copyWechatId">
        <text class="support-icon">💬</text>
        <text class="support-text">遇到问题？联系客服</text>
        <text class="support-id">news-tomato</text>
      </view>
    </view>

  </view>

  <!-- ========== 步骤2：加载中 ========== -->
  <view wx:if="{{step === 'loading'}}" class="step-loading">
    <view class="loading-cosmos">
      <view class="cosmos-ring ring1">
        <text class="orbit-star s1">⭐</text>
      </view>
      <view class="cosmos-ring ring2">
        <text class="orbit-star s2">✨</text>
      </view>
      <view class="cosmos-ring ring3">
        <text class="orbit-star s3">💫</text>
      </view>
      <view class="cosmos-center">🔮</view>
    </view>
    <view class="loading-text">{{loadingText}}</view>
    <view class="loading-steps">
      <view class="ls-dot {{loadingStep >= 0 ? 'done' : ''}}"></view>
      <view class="ls-dot {{loadingStep >= 1 ? 'done' : ''}}"></view>
      <view class="ls-dot {{loadingStep >= 2 ? 'done' : ''}}"></view>
      <view class="ls-dot {{loadingStep >= 3 ? 'done' : ''}}"></view>
      <view class="ls-dot {{loadingStep >= 4 ? 'done' : ''}}"></view>
    </view>
  </view>

  <!-- ========== 步骤3：结果页 ========== -->
  <view wx:if="{{step === 'result'}}" class="step-result">

    <!-- 星盘徽章 -->
    <view class="astro-banner">
      <view class="astro-tag">
        <text class="at-symbol">{{astroSummary.zodiac.symbol}}</text>
        <text class="at-name">{{astroSummary.zodiac.name}}</text>
      </view>
      <view class="astro-divider">×</view>
      <view class="astro-tag soulmate-tag">
        <text class="at-symbol">💖</text>
        <text class="at-name">灵魂伴侣</text>
      </view>
      <view class="astro-divider">×</view>
      <view class="astro-tag">
        <text class="at-symbol">🌙</text>
        <text class="at-name">{{astroSummary.moonSign}}</text>
      </view>
    </view>

    <!-- 核心卡片：灵魂伴侣 -->
    <view class="soulmate-card">

      <!-- 标题 -->
      <view class="sm-title">你的最佳配对星座</view>
      <view class="sm-subtitle">
        你是 {{astroSummary.zodiac.name}}，与 {{astroSummary.soulmateZodiac}} 星座最为契合
      </view>

      <!-- 头像区域 - 直接显示星座配对图 -->
      <view class="avatar-zone">
        <view class="avatar-unlocked-wrap">
          <!-- 显示本地星座头像图片 -->
          <block wx:if="{{soulmate.imageUrl}}">
            <image
              class="unlocked-image"
              src="{{soulmate.imageUrl}}"
              mode="aspectFill"
              bindlongpress="onLongPressImage"
            />
          </block>
          <!-- 渐变色头像 -->
          <block wx:else>
            <view 
              class="unlocked-avatar"
              style="background: {{soulmate.avatarStyle}};"
            >
              <view class="ua-hair" style="background: {{soulmate.hairColor}};"></view>
              <view class="ua-face" style="background: {{soulmate.skinColor}};"></view>
            </view>
          </block>
          <view class="unlocked-badge">
            <text>{{astroSummary.soulmateZodiac}} ✨</text>
          </view>
          <view class="longpress-hint">长按图片可保存</view>
        </view>
      </view>

      <!-- 灵魂伴侣描述 -->
      <view class="sm-desc-wrap">
        <view class="sm-desc-quote">"</view>
        <view class="sm-desc">{{soulmate.desc}}</view>
        <view class="sm-desc-quote end-quote">"</view>
      </view>

      <!-- 星盘详情 -->
      <view class="astro-detail">
        <view class="ad-item">
          <text class="ad-label">太阳星座</text>
          <text class="ad-value">{{astroSummary.zodiac.symbol}} {{astroSummary.zodiac.name}}</text>
        </view>
        <view class="ad-item">
          <text class="ad-label">上升星座</text>
          <text class="ad-value">↑ {{astroSummary.ascendant}}</text>
        </view>
        <view class="ad-item">
          <text class="ad-label">月亮星座</text>
          <text class="ad-value">🌙 {{astroSummary.moonSign}}</text>
        </view>
        <view class="ad-item">
          <text class="ad-label">灵魂伴侣</text>
          <text class="ad-value ad-highlight">💕 {{astroSummary.soulmateZodiac}}</text>
        </view>
      </view>

    </view>

    <!-- 免责声明 -->
    <view class="ai-disclaimer">
      <text class="ai-disclaimer-text">本功能基于星座知识库生成，仅供娱乐参考，不代表任何真实建议</text>
    </view>

    <!-- 底部按钮组 -->
    <view class="result-actions">

      <!-- 操作按钮 -->
      <view class="unlocked-actions">
        <view class="ua-btn" bindtap="saveImage">
          <text class="ua-icon">📥</text>
          <text>保存图片</text>
        </view>
        <button
          class="ua-btn ua-share-btn"
          open-type="share"
        >
          <text class="ua-icon">📤</text>
          <text>分享好友</text>
        </button>
      </view>

      <!-- 重新测试 -->
      <view class="regen-btn" bindtap="goBack">
        <text>🔄 重新测试</text>
      </view>

    </view>

  </view>

</view>
