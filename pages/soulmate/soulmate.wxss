/* pages/soulmate/soulmate.wxss - 全面升级版 */

/* ===== 全局变量 ===== */
page {
  background: #0d0d1e;
  color: #ffffff;
  font-family: -apple-system, 'PingFang SC', sans-serif;
}

.soulmate-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0d0d1e 0%, #1a0a2e 50%, #0d1528 100%);
}

/* ===== 输入页 ===== */
.step-input {
  padding-bottom: 60rpx;
}

/* 头部 */
.input-header {
  position: relative;
  padding: 80rpx 40rpx 48rpx;
  text-align: center;
  overflow: hidden;
}

.input-header-bg {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 300rpx;
  background: radial-gradient(ellipse at 50% 0%, rgba(139, 92, 246, 0.4) 0%, transparent 70%);
}

.input-zodiac-row {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.iz-symbol {
  font-size: 32rpx;
  color: rgba(196, 181, 253, 0.6);
  animation: float 3s ease-in-out infinite;
}

.iz-symbol:nth-child(2) { animation-delay: 0.5s; }
.iz-symbol:nth-child(3) { animation-delay: 1s; }
.iz-symbol:nth-child(4) { animation-delay: 1.5s; }
.iz-symbol:nth-child(5) { animation-delay: 2s; }
.iz-symbol:nth-child(6) { animation-delay: 2.5s; }

@keyframes float {
  0%, 100% { transform: translateY(0); opacity: 0.6; }
  50% { transform: translateY(-8rpx); opacity: 1; }
}

.input-title-wrap {
  padding: 24rpx 0;
}

.input-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 4rpx;
  text-shadow: 0 0 30rpx rgba(167, 139, 250, 0.8);
}

.input-subtitle {
  font-size: 26rpx;
  color: rgba(196, 181, 253, 0.8);
  margin-top: 12rpx;
}

/* 表单卡片 */
.form-card {
  margin: 0 28rpx;
  background: rgba(255, 255, 255, 0.07);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 32rpx;
  padding: 36rpx 32rpx;
  backdrop-filter: blur(20rpx);
}

.form-group {
  margin-bottom: 36rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: rgba(196, 181, 253, 0.9);
  font-weight: 500;
  margin-bottom: 16rpx;
}

.form-label-icon {
  font-size: 28rpx;
}

.optional-tag {
  font-size: 22rpx;
  color: rgba(196, 181, 253, 0.5);
}

/* 性别选择 */
.gender-row {
  display: flex;
  gap: 20rpx;
}

.gender-opt {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 0;
  border-radius: 20rpx;
  border: 1.5rpx solid rgba(255, 255, 255, 0.15);
  background: rgba(255, 255, 255, 0.05);
  transition: all 0.25s;
}

.gender-opt.active {
  border-color: #a78bfa;
  background: rgba(167, 139, 250, 0.2);
  box-shadow: 0 0 20rpx rgba(167, 139, 250, 0.3);
}

.gender-icon { font-size: 36rpx; }
.gender-text { font-size: 28rpx; color: rgba(255, 255, 255, 0.85); font-weight: 500; }

/* 日期输入 */
.date-row {
  display: flex;
  gap: 16rpx;
}

.date-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 0 20rpx;
  height: 80rpx;
}

.date-input {
  flex: 1;
  font-size: 30rpx;
  color: #ffffff;
  text-align: center;
}

.date-unit {
  font-size: 24rpx;
  color: rgba(196, 181, 253, 0.6);
}

/* 城市输入 */
.city-input-wrap {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
}

.city-input {
  flex: 1;
  font-size: 28rpx;
  color: #ffffff;
}

/* 生成按钮 */
.generate-btn {
  margin: 36rpx 28rpx 0;
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
  border-radius: 60rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 40rpx rgba(139, 92, 246, 0.5);
}

.generate-btn-icon { font-size: 36rpx; }
.generate-btn-text { font-size: 34rpx; font-weight: 700; color: #fff; letter-spacing: 2rpx; }

/* 输入页底部 */
.input-footer {
  text-align: center;
  padding: 24rpx 40rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
}

/* ===== 加载页 ===== */
.step-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 60rpx 40rpx;
}

.loading-cosmos {
  position: relative;
  width: 300rpx;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
}

.cosmos-orbit {
  position: absolute;
  border-radius: 50%;
  border: 1.5rpx solid rgba(167, 139, 250, 0.3);
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.orbit1 { width: 160rpx; height: 160rpx; animation: spin 4s linear infinite; }
.orbit2 { width: 220rpx; height: 220rpx; animation: spin 6s linear infinite reverse; }
.orbit3 { width: 280rpx; height: 280rpx; animation: spin 8s linear infinite; }

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.orbit-planet {
  font-size: 28rpx;
  margin-top: -14rpx;
  animation: counter-spin 4s linear infinite;
}

.p2 { animation-duration: 6s; animation-direction: reverse; }
.p3 { animation-duration: 8s; }

@keyframes counter-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(-360deg); }
}

.cosmos-core {
  font-size: 64rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}

.loading-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.loading-text {
  font-size: 26rpx;
  color: rgba(196, 181, 253, 0.8);
  margin-bottom: 48rpx;
  text-align: center;
}

.loading-steps {
  display: flex;
  gap: 16rpx;
}

.ls-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transition: all 0.4s;
}

.ls-dot.done {
  background: #a78bfa;
  box-shadow: 0 0 12rpx rgba(167, 139, 250, 0.8);
}

/* ===== 结果页 ===== */
.step-result {
  padding-bottom: 80rpx;
}

/* 顶部 Hero */
.result-hero {
  position: relative;
  padding: 60rpx 40rpx 40rpx;
  overflow: hidden;
}

.result-hero-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(180deg, rgba(139, 92, 246, 0.3) 0%, transparent 100%);
}

.rh-zodiac-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.rh-my-zodiac,
.rh-soulmate-zodiac {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.rhz-symbol {
  font-size: 64rpx;
  line-height: 1;
  filter: drop-shadow(0 0 12rpx rgba(167, 139, 250, 0.6));
}

.soulmate-color {
  filter: drop-shadow(0 0 12rpx rgba(236, 72, 153, 0.6));
}

.rhz-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

.rhz-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.rh-heart-divider {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.rh-heart {
  font-size: 48rpx;
  animation: heartbeat 1.5s ease-in-out infinite;
}

@keyframes heartbeat {
  0%, 100% { transform: scale(1); }
  25% { transform: scale(1.2); }
  50% { transform: scale(1); }
  75% { transform: scale(1.1); }
}

.rh-compat-score {
  font-size: 48rpx;
  font-weight: 800;
  color: #fbbf24;
  text-shadow: 0 0 20rpx rgba(251, 191, 36, 0.6);
  line-height: 1;
}

.rh-compat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 双人物卡片 */
.couple-cards-wrap {
  display: flex;
  align-items: center;
  gap: 0;
  padding: 0 24rpx 32rpx;
}

.couple-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.07);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 28rpx;
  padding: 24rpx 16rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  position: relative;
  backdrop-filter: blur(10rpx);
}

.my-card {
  border-color: rgba(167, 139, 250, 0.4);
  background: rgba(167, 139, 250, 0.08);
}

.soulmate-card-new {
  border-color: rgba(236, 72, 153, 0.4);
  background: rgba(236, 72, 153, 0.08);
}

.cc-label-tag {
  position: absolute;
  top: -20rpx;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
}

.my-tag {
  background: linear-gradient(135deg, #7c3aed, #a78bfa);
  color: #fff;
}

.soulmate-tag-new {
  background: linear-gradient(135deg, #be185d, #ec4899);
  color: #fff;
}

.cc-avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.2);
  object-fit: cover;
}

.cc-avatar-placeholder {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.2);
}

.cc-zodiac-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
}

.cc-zodiac-keyword {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
  text-align: center;
}

/* 中间匹配环 */
.couple-match-center {
  width: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.match-ring {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.5), rgba(236, 72, 153, 0.5));
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.match-ring-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
}

.match-stars {
  font-size: 20rpx;
  color: #fbbf24;
  letter-spacing: 2rpx;
}

/* 详情卡片 */
.result-detail-card {
  margin: 0 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 36rpx 32rpx;
  backdrop-filter: blur(10rpx);
}

/* 星盘信息行 */
.astro-info-row {
  display: flex;
  gap: 0;
  margin-bottom: 32rpx;
}

.air-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 8rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  margin: 0 6rpx;
}

.air-icon {
  font-size: 32rpx;
}

.air-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.air-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
  text-align: center;
}

/* 分割线 */
.divider-line {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.08);
  margin: 4rpx 0 32rpx;
}

/* 配对描述 */
.compat-desc-wrap {
  margin-bottom: 32rpx;
}

.cdw-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: rgba(196, 181, 253, 0.9);
  margin-bottom: 16rpx;
}

.cdw-icon { font-size: 28rpx; }

.cdw-text {
  font-size: 26rpx;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.04);
  border-left: 4rpx solid #a78bfa;
  padding: 20rpx 20rpx 20rpx 24rpx;
  border-radius: 0 16rpx 16rpx 0;
}

/* 四维契合度 */
.compat-bars-wrap {
  margin-bottom: 32rpx;
}

.cbw-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: rgba(196, 181, 253, 0.9);
  margin-bottom: 20rpx;
}

.cbw-icon { font-size: 28rpx; }

.compat-bar-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.cbi-label {
  width: 100rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  flex-shrink: 0;
}

.cbi-track {
  flex: 1;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 6rpx;
  overflow: hidden;
}

.cbi-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.8s ease;
}

.cbi-value {
  width: 52rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #fbbf24;
  text-align: right;
  flex-shrink: 0;
}

/* 优劣势分析 */
.pro-con-wrap {
  display: flex;
  gap: 20rpx;
}

.pc-col {
  flex: 1;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 20rpx;
  padding: 20rpx;
}

.pc-title {
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.pc-title.pros { color: #34d399; }
.pc-title.cons { color: #fbbf24; }

.pc-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.pc-dot {
  color: rgba(255, 255, 255, 0.4);
  flex-shrink: 0;
}

/* 底部操作 */
.result-actions {
  display: flex;
  gap: 20rpx;
  margin: 32rpx 24rpx 0;
}

.ra-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.save-btn {
  background: rgba(167, 139, 250, 0.2);
  border: 1.5rpx solid rgba(167, 139, 250, 0.5);
  color: #c4b5fd;
}

.save-btn::after { border: none; }

.share-btn {
  background: linear-gradient(135deg, #8b5cf6, #ec4899);
  color: #ffffff;
  box-shadow: 0 4rpx 24rpx rgba(139, 92, 246, 0.4);
}

.share-btn::after { border: none; }

.ra-icon { font-size: 30rpx; }

.retest-btn {
  margin: 24rpx 24rpx 0;
  height: 80rpx;
  border: 1.5rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.result-disclaimer {
  text-align: center;
  padding: 24rpx 40rpx 0;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.3);
  line-height: 1.6;
}
