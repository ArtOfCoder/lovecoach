/* pages/user-stats/user-stats.wxss */

.stats-page {
  min-height: 100vh;
  background: #f8f8fc;
  padding-bottom: 140rpx;
}

/* 确保所有文字颜色为黑色 - 使用更具体的选择器 */
.stats-page .overview-label,
.stats-page .module-time,
.stats-page .log-time,
.stats-page .chat-time,
.stats-page .chat-label,
.stats-page .empty-tip,
.stats-page .count-label,
.stats-page .soulmate-desc,
.stats-page .loading-text,
.stats-page .section-title,
.stats-page .module-name,
.stats-page .log-action,
.stats-page .chat-text,
.stats-page .chat-answer .chat-text,
.stats-page .clear-btn,
.stats-page .tab-item,
.stats-page .overview-num,
.stats-page .count-num,
.stats-page .module-count text,
.stats-page .log-content text,
.stats-page .chat-header text,
.stats-page .chat-question text,
.stats-page .chat-answer text,
.stats-page .overview-title,
.stats-page .overview-subtitle,
.stats-page .soulmate-count,
.stats-page .soulmate-arrow,
.stats-page .module-icon text,
.stats-page .btn-icon,
.stats-page .footer-actions text,
.stats-page .empty-tip text,
.stats-page .chat-mode {
  color: #000000 !important;
}

/* 白色背景上的文字 */
.stats-page .overview-card .overview-title,
.stats-page .overview-card .overview-subtitle,
.stats-page .overview-card .overview-num,
.stats-page .overview-card .overview-label,
.stats-page .tab-item.active,
.stats-page .tab-item.active text {
  color: #ffffff !important;
}

/* Tab 非选中状态 */
.stats-page .tab-item:not(.active),
.stats-page .tab-item:not(.active) text {
  color: #666666 !important;
}

/* 加载中 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #FF6B8A;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

/* 概览卡片 */
.overview-card {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8E9B 100%);
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 138, 0.3);
}

.overview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.overview-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.overview-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.overview-stats {
  display: flex;
  justify-content: space-around;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.overview-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 8rpx;
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8E9B 100%);
  color: #fff;
  font-weight: 500;
}

/* Tab 内容 */
.tab-content {
  padding: 0 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin: 30rpx 0 20rpx 10rpx;
}

/* 功能列表 */
.module-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.module-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.module-item:last-child {
  border-bottom: none;
}

.module-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.module-info {
  flex: 1;
}

.module-name {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.module-time {
  font-size: 26rpx;
  color: #666;
}

.module-count {
  display: flex;
  align-items: baseline;
}

.count-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF6B8A;
}

.count-label {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
}

/* 灵魂伴侣卡片 */
.soulmate-section {
  margin-top: 30rpx;
}

.soulmate-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #FFF5F7 0%, #FFE4EC 100%);
  padding: 30rpx;
  border-radius: 16rpx;
  margin: 0 10rpx;
}

.soulmate-info {
  flex: 1;
}

.soulmate-count {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6B8A;
  margin-bottom: 8rpx;
}

.soulmate-desc {
  font-size: 24rpx;
  color: #999;
}

.soulmate-arrow {
  font-size: 40rpx;
  color: #FF6B8A;
}

/* 使用记录 */
.log-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.log-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.log-item:last-child {
  border-bottom: none;
}

.log-dot {
  width: 16rpx;
  height: 16rpx;
  background: #FF6B8A;
  border-radius: 50%;
  margin-right: 20rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.log-content {
  flex: 1;
}

.log-action {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.log-time {
  font-size: 24rpx;
  color: #999;
}

/* AI对话 */
.chat-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.chat-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.chat-item:last-child {
  border-bottom: none;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.chat-mode {
  font-size: 26rpx;
  color: #FF6B8A;
  background: #FFF5F7;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.chat-time {
  font-size: 24rpx;
  color: #999;
}

.chat-question, .chat-answer {
  display: flex;
  margin-bottom: 12rpx;
}

.chat-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.chat-text {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.chat-answer .chat-text {
  color: #666;
}

/* 空提示 */
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 底部操作 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.clear-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  background: #f5f5f5;
  color: #333;
  font-size: 32rpx;
  border-radius: 50rpx;
  border: none;
}

.clear-btn::after {
  border: none;
}

.btn-icon {
  margin-right: 8rpx;
}
