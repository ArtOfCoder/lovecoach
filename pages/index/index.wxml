<!-- pages/index/index.wxml - 全面升级版 -->
<view class="page-wrap">

  <!-- 功能提示 -->
  <view class="feature-tip" bindtap="goToAI">
    <view class="act-icon">⚡</view>
    <view class="act-text">恋爱顾问在线，随时为你解答疑惑 →</view>
  </view>

  <!-- 顶部 Hero -->
  <view class="hero gradient-bg">
    <view class="hero-row">
      <view class="hero-left">
        <view class="hero-greeting">{{greeting}} 👋</view>
        <view class="hero-name">{{userNickname || '恋爱进化论'}}</view>
        <view class="hero-sub">科学谈恋爱，感情更有温度</view>
      </view>
      <view class="hero-avatar-wrap" bindtap="goToProfile">
        <view class="hero-avatar">{{userNickname ? userNickname[0] : '💕'}}</view>
        <view class="streak-badge" wx:if="{{streakDays > 1}}">{{streakDays}}天</view>
      </view>
    </view>

    <!-- 性别切换 -->
    <view class="gender-switch">
      <view class="gender-btn {{activeGender === 'male' ? 'active' : ''}}" bindtap="switchGender" data-gender="male">
        <text>👦</text><text> 男生专区</text>
      </view>
      <view class="gender-btn {{activeGender === 'female' ? 'active' : ''}}" bindtap="switchGender" data-gender="female">
        <text>👧</text><text> 女生专区</text>
      </view>
    </view>
  </view>

  <!-- 新用户引导横幅（没有档案 & 没有昵称时显示） -->
  <view wx:if="{{showNewUserGuide}}" class="new-user-guide">
    <view class="nug-icon">🌱</view>
    <view class="nug-content">
      <view class="nug-title">欢迎来到恋爱进化论！</view>
      <view class="nug-sub">创建情侣档案，解锁专属恋爱建议和里程碑追踪</view>
    </view>
    <view class="nug-btn" bindtap="goToCouple">立即创建 →</view>
  </view>

  <!-- 今日任务卡片（打卡） -->
  <view class="section-wrap">
    <view class="daily-task-card" bindtap="goToDaily">
      <view class="daily-task-left">
        <view class="daily-icon">{{todayTaskDone ? '🎉' : '📋'}}</view>
        <view class="daily-task-info">
          <view class="daily-task-title">{{todayTaskDone ? '今日任务完成！' : '今日任务'}}</view>
          <view class="daily-task-sub">{{todayTask}}</view>
        </view>
      </view>
      <view class="daily-task-right">
        <view class="daily-task-btn {{todayTaskDone ? 'done' : ''}}">
          {{todayTaskDone ? '已完成' : '去完成'}}
        </view>
      </view>
    </view>
  </view>

  <!-- 今日金句 -->
  <view class="section-wrap">
    <view class="daily-word-card card">
      <view class="dw-left">
        <view class="dw-tag">✨ 今日金句</view>
        <view class="dw-text">"{{dailyWord}}"</view>
      </view>
      <view class="dw-share" bindtap="shareWord">分享</view>
    </view>
  </view>

  <!-- 核心功能 Banner -->
  <view class="section-wrap">
    <!-- 聊天回复生成器 - 主入口大卡 -->
    <view class="hero-feature-card" bindtap="goToChatReply">
      <view class="hfc-badge">🔥 最受欢迎功能</view>
      <view class="hfc-title">聊天回复生成</view>
      <view class="hfc-sub">粘贴 TA 的消息，快速生成高情商回复</view>
      <view class="hfc-demo">
        <view class="demo-bubble-ta">你最近怎么样？</view>
        <view class="demo-arrow">→ 快速生成</view>
        <view class="demo-bubble-me">还在忙那个项目，不过每天都在期待跟你聊天，这算不算一种动力 😄</view>
      </view>
      <view class="hfc-btn">立即试用 →</view>
    </view>
  </view>

  <!-- 第二行：情侣档案 + 恋爱顾问双入口 -->
  <view class="section-wrap">
    <view class="dual-card-row">
      <view class="dual-card" bindtap="goToCouple" style="background:linear-gradient(135deg,#fff5f9,#f5f0ff)">
        <view class="dc-icon">💑</view>
        <view class="dc-title">情侣档案</view>
        <view class="dc-sub">创建档案<br/>获取专属恋爱建议</view>
        <view class="dc-badge">NEW</view>
      </view>
      <view class="dual-card" bindtap="goToAI" style="background:linear-gradient(135deg,#f0f9ff,#f0f4ff)">
        <view class="dc-icon">💕</view>
        <view class="dc-title">恋爱顾问</view>
        <view class="dc-sub">24小时在线<br/>倾诉、提问、求建议</view>
      </view>
    </view>
  </view>

  <!-- 灵魂伴侣特色入口 Banner -->
  <view class="section-wrap">
    <view class="soulmate-banner" bindtap="goToSoulmate">
      <view class="smb-left">
        <view class="smb-tag">🔮 星盘测算</view>
        <view class="smb-title">测算你的灵魂伴侣</view>
        <view class="smb-sub">输入出生日期，解析星盘命格，找到命中注定的另一半</view>
      </view>
      <view class="smb-right">
        <view class="smb-avatar-demo">
          <view class="smb-blur-face">✨</view>
        </view>
        <view class="smb-price">解锁 ¥9.9</view>
      </view>
    </view>
  </view>

  <!-- 功能导航宫格 -->
  <view class="section-wrap">
    <view class="quick-grid-4">
      <view class="qg-cell" bindtap="goToSoulmate">
        <view class="qg-icon" style="background:linear-gradient(135deg,#ede9fe,#fce7f3);">🔮</view>
        <view class="qg-label">灵魂伴侣</view>
      </view>
      <view class="qg-cell" bindtap="goToQuiz">
        <view class="qg-icon" style="background:#ede9fe;">🧠</view>
        <view class="qg-label">恋爱测评</view>
      </view>
      <view class="qg-cell" bindtap="goToTopics">
        <view class="qg-icon" style="background:#dcfce7;">🗂️</view>
        <view class="qg-label">话题库</view>
      </view>
      <view class="qg-cell" bindtap="goToRoleplay">
        <view class="qg-icon" style="background:#f0fdf4;">🎭</view>
        <view class="qg-label">角色练习</view>
      </view>
    </view>
  </view>

  <!-- 推荐课程 -->
  <view class="section-wrap">
    <view class="section-header">
      <view class="section-title-text">{{activeGender === 'male' ? '👦 男生必学' : '👧 女生必学'}}</view>
      <view class="section-more" bindtap="goToCourse">全部 ></view>
    </view>
    <scroll-view scroll-x enable-flex class="course-hscroll">
      <view class="course-hscroll-inner">
        <view
          class="course-h-card"
          wx:for="{{recommendCourses}}"
          wx:key="id"
          bindtap="goToDetail"
          data-id="{{item.id}}"
        >
          <view class="chc-cover" style="background:{{item.coverBg}}">
            <text class="chc-emoji">{{item.cover}}</text>
            <view wx:if="{{item.isFree}}" class="chc-free">免费</view>
          </view>
          <view class="chc-info">
            <view class="chc-cat">{{item.category}}</view>
            <view class="chc-title">{{item.title}}</view>
            <view class="chc-meta">
              <text>⏱ {{item.duration}}</text>
              <text style="margin-left:16rpx;">👁 {{item.views}}</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 热门问题（带AI跳转） -->
  <view class="section-wrap">
    <view class="section-header">
      <view class="section-title-text">🔥 大家都在问</view>
    </view>
    <view class="hot-questions">
      <view
        class="hot-q-item"
        wx:for="{{hotQuestions}}"
        wx:key="*this"
        bindtap="askAI"
        data-q="{{item}}"
      >
        <view class="hot-q-icon">Q</view>
        <view class="hot-q-text">{{item}}</view>
        <view class="hot-q-arrow">→</view>
      </view>
    </view>
  </view>

  <!-- 学习进度 -->
  <view class="section-wrap">
    <view class="section-title-text" style="margin-bottom:16rpx;">📈 学习进度</view>
    <view class="progress-card card">
      <view class="progress-stats">
        <view class="ps-item">
          <view class="ps-num">{{learnedCount}}</view>
          <view class="ps-label">已学课程</view>
        </view>
        <view class="ps-divider"></view>
        <view class="ps-item">
          <view class="ps-num">{{totalMinutes}}</view>
          <view class="ps-label">学习分钟</view>
        </view>
        <view class="ps-divider"></view>
        <view class="ps-item">
          <view class="ps-num">{{streakDays}}</view>
          <view class="ps-label">连续打卡</view>
        </view>
      </view>
      <view class="progress-bar-wrap">
        <view class="progress-track">
          <view class="progress-fill" style="width:{{progressPercent}}%"></view>
        </view>
        <view class="progress-tip">距离完成初级目标还差 {{remainCourses}} 节</view>
      </view>
    </view>
  </view>

  <!-- 免责声明 -->
  <view style="text-align:center;padding:20rpx 40rpx 80rpx;">
    <text style="font-size:22rpx;color:#999;">内容由本地知识库生成，仅供学习参考</text>
  </view>
  
  <view style="height:120rpx;"></view>
</view>
