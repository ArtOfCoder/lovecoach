<!-- pages/course/course.wxml -->
<view class="container">

  <!-- 顶部 -->
  <view class="header gradient-bg">
    <view class="header-row">
      <view class="header-left">
        <view class="header-title">恋爱课程 📚</view>
        <view class="header-sub">共 {{totalCount}} 门课程，系统提升情感能力</view>
      </view>
      <view class="header-search-btn" bindtap="toggleSearch">
        <text>{{showSearch ? '×' : '🔍'}}</text>
      </view>
    </view>
  </view>

  <!-- 搜索框 -->
  <view wx:if="{{showSearch}}" class="search-bar">
    <input
      class="search-input"
      placeholder="搜索课程标题、关键词..."
      value="{{searchKeyword}}"
      bindinput="onSearchInput"
      focus="{{showSearch}}"
    />
    <view wx:if="{{searchKeyword}}" class="search-clear" bindtap="clearSearch">×</view>
  </view>

  <!-- 性别筛选 -->
  <view class="filter-bar">
    <view
      class="filter-tab {{genderFilter === 'all' ? 'active' : ''}}"
      bindtap="setFilter" data-type="gender" data-val="all">全部</view>
    <view
      class="filter-tab {{genderFilter === 'male' ? 'active' : ''}}"
      bindtap="setFilter" data-type="gender" data-val="male">👦 男生</view>
    <view
      class="filter-tab {{genderFilter === 'female' ? 'active' : ''}}"
      bindtap="setFilter" data-type="gender" data-val="female">👧 女生</view>
  </view>

  <!-- 分类标签 -->
  <scroll-view scroll-x class="cat-scroll">
    <view class="cat-inner">
      <view
        wx:for="{{categories}}"
        wx:key="*this"
        class="cat-tag {{activeCategory === item ? 'cat-active' : ''}}"
        bindtap="setCategory" data-cat="{{item}}">{{item}}</view>
    </view>
  </scroll-view>

  <!-- 课程区域 -->
  <view class="section-title-row">
    <view class="section-ttl-txt">
      📚 {{activeCategory === '全部' ? '全部课程' : activeCategory + '系列'}}
      <text class="count-badge">{{filteredCourses.length}}</text>
    </view>
  </view>

  <!-- 课程列表 -->
  <view class="course-list">
    <view
      class="course-item card"
      wx:for="{{filteredCourses}}"
      wx:key="id"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <view class="item-cover" style="background:{{item.coverBg || '#764ba2'}}">
        <text class="item-emoji">{{item.cover}}</text>
        <view wx:if="{{item.isFree}}" class="free-badge">免费</view>
        <view wx:if="{{learnedMap[item.id]}}" class="done-badge">✓</view>
        <view wx:if="{{item.hot}}" class="hot-badge">🔥</view>
      </view>
      <view class="item-info">
        <view class="item-top">
          <text class="tag tag-pink">{{item.category}}</text>
          <text class="item-gender-tag" style="color:{{item.gender==='male'?'#3b82f6':item.gender==='female'?'#ec4899':'#8b5cf6'}}">
            {{item.gender === 'male' ? '👦男生' : item.gender === 'female' ? '👧女生' : '💑通用'}}
          </text>
        </view>
        <view class="item-title">{{item.title}}</view>
        <view class="item-desc">{{item.desc}}</view>
        <view class="item-footer">
          <text class="item-duration">⏱ {{item.duration}}</text>
          <text class="item-views">👁 {{item.views}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{filteredCourses.length === 0}}" class="empty">
      <view class="empty-icon">🔍</view>
      <text class="empty-text">{{searchKeyword ? '没有找到匹配的课程' : '暂无相关课程'}}</text>
      <view wx:if="{{searchKeyword}}" class="empty-hint" bindtap="clearSearch">清除搜索</view>
    </view>
  </view>

  <view style="height:40rpx"></view>
</view>
