/* pages/soulmate-history/soulmate-history.wxss */

.history-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F7 0%, #f8f8fc 100%);
  padding-bottom: 140rpx;
}

/* 确保所有文字颜色为黑色 - 使用更具体的选择器 */
.history-page .date-text,
.history-page .birth-info,
.history-page .desc-text,
.history-page .loading-text,
.history-page .empty-title,
.history-page .card-zodiac,
.history-page .card-soulmate-zodiac,
.history-page .action-btn,
.history-page .footer-btn,
.history-page .delete-btn,
.history-page .clear-btn,
.history-page .stat-label,
.history-page .card-arrow,
.history-page .btn-icon,
.history-page .empty-icon,
.history-page .card-tag,
.history-page .header-stats .stat-label {
  color: #000000 !important;
}

/* 粉色背景上的白色文字 */
.history-page .header-stats .stat-num,
.history-page .header-stats .stat-label {
  color: #ffffff !important;
}

/* 顶部统计 */
.header-stats {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8E9B 100%);
  margin: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 138, 0.3);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 8rpx;
}

/* 加载中 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #FF6B8A;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 28rpx;
  color: #999;
  line-height: 1.6;
  margin-bottom: 40rpx;
  white-space: pre-line;
}

.empty-btn {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8E9B 100%);
  color: #fff;
  font-size: 32rpx;
  padding: 24rpx 80rpx;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 138, 0.4);
}

.empty-btn::after {
  border: none;
}

/* 历史列表 */
.history-list {
  padding: 20rpx;
}

.history-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.card-image-wrap {
  position: relative;
  width: 100%;
  height: 400rpx;
  background: linear-gradient(135deg, #FFE4EC 0%, #FFF0F3 100%);
}

.card-image {
  width: 100%;
  height: 100%;
}

.card-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: rgba(255, 107, 138, 0.9);
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

.card-info {
  padding: 30rpx;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-zodiac {
  font-size: 34rpx;
  font-weight: bold;
  color: #000;
}

.card-arrow {
  font-size: 28rpx;
  color: #FF6B8A;
  margin: 0 16rpx;
}

.card-soulmate-zodiac {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6B8A;
}

.card-date {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.date-text {
  font-size: 24rpx;
  color: #999;
}

.birth-info {
  font-size: 24rpx;
  color: #666;
}

.card-desc {
  background: #FFF5F7;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
  border: none;
}

.action-btn::after {
  border: none;
}

.save-btn {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8E9B 100%);
  color: #fff;
}

.delete-btn {
  background: #f5f5f5;
  color: #999;
}

.btn-icon {
  margin-right: 8rpx;
}

/* 底部操作栏 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.footer-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  border-radius: 50rpx;
  font-size: 30rpx;
  border: none;
}

.footer-btn::after {
  border: none;
}

.clear-btn {
  background: #f5f5f5;
  color: #666;
}

.primary-btn {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8E9B 100%);
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 138, 0.4);
}
