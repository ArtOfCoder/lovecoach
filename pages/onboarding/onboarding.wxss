/* pages/onboarding/onboarding.wxss - 用户资料设置页样式 */

.ob-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #ff6b9d 0%, #c44fcb 40%, #7c5dfa 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  box-sizing: border-box;
  position: relative;
}

/* 返回按钮 */
.ob-back {
  position: absolute;
  top: 40rpx;
  left: 32rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx;
  z-index: 10;
}

.ob-back-icon {
  font-size: 32rpx;
}

.ob-wrap {
  width: 90%;
  max-width: 680rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 56rpx 40rpx 48rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ob-logo {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  animation: bounce 1.2s ease-in-out infinite alternate;
}

@keyframes bounce {
  from { transform: translateY(0); }
  to { transform: translateY(-10rpx); }
}

.ob-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 12rpx;
}

.ob-sub {
  font-size: 28rpx;
  color: #888;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

/* 性别选择区 */
.ob-section {
  width: 100%;
  margin-bottom: 40rpx;
}

.ob-section-title {
  font-size: 30rpx;
  color: #555;
  text-align: center;
  margin-bottom: 24rpx;
}

.ob-gender-row {
  display: flex;
  gap: 24rpx;
}

.ob-gender-card {
  flex: 1;
  border: 3rpx solid #e5e7eb;
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  transition: all 0.2s;
  background: #fafafa;
}

.ob-gender-card.selected {
  border-color: #ff6b9d;
  background: linear-gradient(135deg, #fff0f5, #fdf0ff);
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 157, 0.2);
}

.ob-gender-emoji {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.ob-gender-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.ob-gender-desc {
  font-size: 22rpx;
  color: #888;
  text-align: center;
  line-height: 1.5;
}

.ob-check {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ff6b9d;
  border-radius: 50%;
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

/* 提示区 */
.ob-tips {
  width: 100%;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 40rpx;
}

.ob-tip-item {
  font-size: 26rpx;
  color: #666;
  padding: 8rpx 0;
  line-height: 1.5;
}

/* 昵称输入 */
.ob-input-wrap {
  width: 100%;
  margin-bottom: 40rpx;
}

.ob-input {
  width: 100%;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  font-size: 32rpx;
  color: #1a1a2e;
  background: #fff;
  box-sizing: border-box;
  line-height: 1.5;
}

.ob-input::placeholder {
  color: #999999;
}

.ob-input:focus {
  border-color: #FF6B8A;
  background: #fff;
}

/* 按钮 */
.ob-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.ob-btn.active {
  background: linear-gradient(135deg, #ff6b9d, #c44fcb);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.35);
}

.ob-btn.disabled {
  background: #e5e7eb;
  color: #aaa;
}

.ob-btn::after {
  border: none;
}

.ob-skip {
  font-size: 26rpx;
  color: #aaa;
  text-align: center;
  padding: 12rpx;
}
