/* pages/ai-coach/ai-coach.wxss */

.page-wrap {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f0f0f8;
}

/* ===== 顶部渐变背景（修复gradient-bg-purple未定义Bug）===== */
.gradient-bg-purple {
  background: linear-gradient(135deg, #6C63FF 0%, #A855F7 60%, #FF6B8A 100%);
}

/* 顶部 */
.ai-header {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  gap: 16rpx;
  flex-shrink: 0;
}
.ai-header-avatar {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}
.ai-header-info { flex: 1; }
.ai-header-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}
.ai-header-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 4rpx;
}
.status-dot {
  width: 14rpx;
  height: 14rpx;
  background: #4ade80;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 0 8rpx #4ade80;
}
.ai-header-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}
.action-btn {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  padding: 8rpx 18rpx;
  border: 1rpx solid rgba(255,255,255,0.4);
  border-radius: 100rpx;
}

/* 模式栏 */
.mode-bar {
  display: flex;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  overflow-x: auto;
}
.mode-bar::-webkit-scrollbar { display: none; }
.mode-item {
  flex-shrink: 0;
  padding: 18rpx 24rpx;
  font-size: 24rpx;
  color: #999999;
  white-space: nowrap;
  position: relative;
}
.mode-item.active {
  color: #6C63FF;
  font-weight: 600;
}
.mode-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 4rpx;
  background: #6C63FF;
  border-radius: 100rpx;
}

/* 快捷问题面板 */
.quick-panel {
  background: #ffffff;
  padding: 24rpx;
  flex-shrink: 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.quick-panel-title {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 16rpx;
}
.quick-panel-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.quick-chip {
  background: #f0effe;
  color: #6C63FF;
  font-size: 24rpx;
  padding: 10rpx 22rpx;
  border-radius: 100rpx;
}

/* 情绪选择 */
.mood-section { margin-top: 4rpx; }
.mood-title {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
}
.mood-row {
  display: flex;
  gap: 20rpx;
}
.mood-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  background: #f8f8fc;
  gap: 6rpx;
  border: 2rpx solid transparent;
}
.mood-item.selected {
  background: #ede9fe;
  border-color: #6C63FF;
}
.mood-emoji { font-size: 36rpx; }
.mood-label { font-size: 20rpx; color: #666666; }

/* 对话滚动区 */
.chat-scroll {
  flex: 1;
  overflow: hidden;
}
.chat-inner {
  padding: 20rpx 16rpx;
}

/* 时间戳 */
.time-stamp {
  text-align: center;
  font-size: 20rpx;
  color: #bbbbbb;
  margin: 16rpx 0;
}

.msg-wrapper { margin-bottom: 4rpx; }

/* 消息行 */
.msg-row {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-end;
}
.ai-row { flex-direction: row; gap: 12rpx; }
.user-row { flex-direction: row-reverse; }

/* AI头像 */
.ai-ava {
  width: 64rpx;
  height: 64rpx;
  background: #ede9fe;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
  align-self: flex-end;
}

.msg-col {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  max-width: 78%;
}

/* 气泡 */
.ai-bubble {
  background: #ffffff;
  border-radius: 24rpx;
  border-bottom-left-radius: 6rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.user-bubble {
  background: #6C63FF;
  border-radius: 24rpx;
  border-bottom-right-radius: 6rpx;
  padding: 20rpx 24rpx;
  max-width: 78%;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}
.ai-bubble .msg-text { color: #1a1a2e; }
.user-bubble .msg-text { color: #ffffff; }

/* 情感标签 */
.emotion-tag {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6C63FF;
  background: #ede9fe;
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
}

/* 追问chips */
.suggestions-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}
.suggest-chip {
  background: #FFE8EE;
  color: #FF6B8A;
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 100rpx;
  flex-shrink: 0;
}

/* 打字动画 */
.typing-row { margin-bottom: 20rpx; }
.typing-bubble {
  padding: 20rpx 28rpx;
}
.typing-dots {
  display: flex;
  gap: 8rpx;
  align-items: center;
  height: 32rpx;
}
.dot {
  width: 14rpx;
  height: 14rpx;
  background: #cccccc;
  border-radius: 50%;
  animation: dotBounce 1.4s infinite ease-in-out;
}
.dot:nth-child(1) { animation-delay: 0s; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* 情感分析卡片 */
.analysis-card {
  position: fixed;
  bottom: 200rpx;
  left: 24rpx;
  right: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
  z-index: 100;
}
.analysis-close {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  color: #999999;
  font-size: 28rpx;
}
.analysis-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}
.analysis-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.7;
}

/* 输入区 */
.input-area {
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  padding: 0 0 env(safe-area-inset-bottom) 0;
}
.input-toolbar {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 16rpx 8rpx;
  overflow-x: auto;
}
.input-toolbar::-webkit-scrollbar { display: none; }
.tool-btn {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #666666;
  background: #f5f5f5;
  padding: 8rpx 18rpx;
  border-radius: 100rpx;
}
.input-row {
  display: flex;
  align-items: center;
  padding: 10rpx 16rpx 16rpx;
  gap: 12rpx;
}
.chat-input {
  flex: 1;
  background: #f5f5f7;
  border-radius: 100rpx;
  padding: 18rpx 28rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  min-height: 72rpx;
  box-sizing: border-box;
}
.send-btn {
  flex-shrink: 0;
  width: 100rpx;
  height: 72rpx;
  border-radius: 100rpx;
  background: #e0e0e0;
  color: #999999;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}
.send-btn.active {
  background: #6C63FF;
  color: #ffffff;
}

/* AI免责声明 */
.ai-footer-notice {
  background: #fafafa;
  padding: 12rpx 24rpx;
  text-align: center;
  border-top: 1rpx solid #f0f0f0;
}
.ai-footer-notice text {
  font-size: 22rpx;
  color: #999;
}
