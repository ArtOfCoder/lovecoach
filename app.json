{
  "networkTimeout": {
    "request": 30000,
    "connectSocket": 20000,
    "uploadFile": 30000,
    "downloadFile": 30000
  },
  "pages": [
    "pages/onboarding/onboarding",
    "pages/index/index",
    "pages/couple/couple",
    "pages/chat-reply/chat-reply",
    "pages/course/course",
    "pages/detail/detail",
    "pages/ai-coach/ai-coach",
    "pages/topics/topics",
    "pages/profile/profile",
    "pages/quiz/quiz",
    "pages/roleplay/roleplay",
    "pages/relationship/relationship",
    "pages/soulmate/soulmate",
    "pages/soulmate-history/soulmate-history",
    "pages/user-stats/user-stats",
    "pages/admin/admin"
